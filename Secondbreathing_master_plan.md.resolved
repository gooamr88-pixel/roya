### 📊 PILLAR 8 — OBSERVABILITY & DEVOPS MASTERY

#### 8.1 Structured JSON Logging — Replace `console.log`
```bash
npm install winston winston-daily-rotate-file
```
```js
// server/middlewares/logger.js — complete replacement
const winston = require('winston');
const logger = winston.createLogger({
  level: 'info',
  format: winston.format.combine(
    winston.format.timestamp(),
    winston.format.errors({ stack: true }),
    winston.format.json()  // Structured JSON — machine-parseable
  ),
  transports: [
    new winston.transports.DailyRotateFile({ filename: 'logs/app-%DATE%.log', maxFiles: '30d' }),
    new winston.transports.DailyRotateFile({ filename: 'logs/error-%DATE%.log', level: 'error', maxFiles: '90d' }),
  ]
});
```

Every request logs: `{ method, url, statusCode, responseTime, userId, ip, userAgent }`.

#### 8.2 Application Performance Monitoring
Integrate **Sentry** for real-time error tracking:
```bash
npm install @sentry/node @sentry/profiling-node
```
```js
// In server.js — before any other middleware
Sentry.init({
  dsn: config.sentry.dsn,
  tracesSampleRate: 0.1,  // 10% of requests for performance profiling
  profilesSampleRate: 0.1,
  integrations: [
    Sentry.postgresIntegration(),  // Auto-trace DB queries
    Sentry.expressIntegration(),
  ],
});
```
Every unhandled error in production creates a Sentry issue with: stack trace, user context, request payload, DB query that triggered it. You get notified by email/Slack within seconds.

#### 8.3 Health Check — Liveness + Readiness Probes
```js
// Upgrade your basic /api/health endpoint:
app.get('/api/health/live', (req, res) => res.json({ status: 'alive' }));

app.get('/api/health/ready', async (req, res) => {
  const checks = await Promise.allSettled([
    pool.query('SELECT 1'),           // DB connectivity
    redis.ping(),                      // Redis connectivity
    emailTransporter.verify(),         // SMTP connectivity
  ]);
  const [db, cache, email] = checks.map(c => c.status === 'fulfilled' ? 'ok' : 'degraded');
  const status = [db, cache, email].every(s => s === 'ok') ? 200 : 503;
  res.status(status).json({ db, cache, email, uptime: process.uptime() });
});
```

#### 8.4 CI/CD Pipeline — GitHub Actions
```yaml
# .github/workflows/deploy.yml
name: Deploy Roya Platform
on:
  push:
    branches: [main]
jobs:
  test:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - run: npm ci
      - run: npm test  # Add Jest tests (see Pillar 9)
  deploy:
    needs: test
    runs-on: ubuntu-latest
    steps:
      - name: Deploy via SSH
        run: |
          ssh ${{ secrets.SERVER_USER }}@${{ secrets.SERVER_IP }} '
            cd /var/www/roya && 
            git pull origin main && 
            npm ci --production && 
            pm2 reload roya --update-env
          '
```
Every push to `main` auto-deploys if tests pass. Zero-touch deployments with PM2 zero-downtime reload.

