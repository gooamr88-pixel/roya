### 📡 PILLAR 4 — REAL-TIME ENGINE

#### 4.1 WebSocket Server (Socket.IO)
```bash
npm install socket.io
```
```js
// server/server.js — attach to existing HTTP server
const { Server } = require('socket.io');
const io = new Server(server, { cors: { origin: config.security.allowedOrigins, credentials: true } });

// Authenticate WebSocket connections using your existing JWT middleware
io.use(async (socket, next) => {
  const token = socket.handshake.auth.token || socket.request.cookies?.access_token;
  try {
    const decoded = jwt.verify(token, config.jwt.accessSecret);
    socket.userId = decoded.userId;
    next();
  } catch { next(new Error('Unauthorized')); }
});

// Join personal room
io.on('connection', (socket) => {
  socket.join(`user:${socket.userId}`);
  socket.on('admin:join', () => socket.join('admin:room'));
});
```

#### 4.2 Real-Time Notifications
```js
// server/services/notification.service.js — upgrade createNotification()
const createNotification = async (userId, title, message, type) => {
  const result = await query(
    `INSERT INTO notifications (user_id, title, message, type) VALUES ($1, $2, $3, $4) RETURNING *`,
    [userId, title, message, type]
  );
  // Push via WebSocket — user gets it instantly, no polling needed
  io.to(`user:${userId}`).emit('notification:new', result.rows[0]);
  return result.rows[0];
};
```

Replace your current notification polling in the dashboard JS with a single WebSocket listener. **This kills dozens of polling `setInterval` calls.**

#### 4.3 Live Admin Dashboard
```js
// Admin stats broadcast every 30 seconds
setInterval(async () => {
  const stats = await getStatsFromCache(); // from Redis materialized cache
  io.to('admin:room').emit('dashboard:stats', stats);
}, 30000);

// Broadcast new order arrival to admin room instantly
io.to('admin:room').emit('order:new', newOrder);
```

