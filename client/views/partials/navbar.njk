{# ═══════════════════════════════════════════════ #}
{# Navbar Partial                                   #}
{# ═══════════════════════════════════════════════ #}
<nav class="navbar" id="navbar">
  <div class="container">
    <a href="/" class="nav-logo" aria-label="Nabda Home">
      <img class="nav-logo-emblem" src="/images/brand-symbol.png" alt="Nabda Emblem" fetchpriority="high">
      <span class="nav-logo-divider"></span>
      <img class="nav-logo-text" src="{{ brandTextSrc }}" alt="{{ logoAlt }}" fetchpriority="high">
    </a>

    <ul class="nav-links" id="navLinks">
      <li><a href="#home" data-i18n="nav.home">{{ t.nav.home }}</a></li>
      <li><a href="#about" data-i18n="nav.about">{{ t.nav.about }}</a></li>
      <li><a href="#services" data-i18n="nav.services">{{ t.nav.services }}</a></li>
      <li>
        <a href="#exhibitions" style="display:inline-flex;align-items:center;gap:6px;">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
            <line x1="16" y1="2" x2="16" y2="6"></line>
            <line x1="8" y1="2" x2="8" y2="6"></line>
            <line x1="3" y1="10" x2="21" y2="10"></line>
            <path d="M8 14h.01"></path><path d="M12 14h.01"></path><path d="M16 14h.01"></path>
            <path d="M8 18h.01"></path><path d="M12 18h.01"></path><path d="M16 18h.01"></path>
          </svg>
          <span data-i18n="nav.exhibitions">{{ t.nav.exhibitions }}</span>
        </a>
      </li>
      <li><a href="#jobs" data-i18n="nav.properties">{{ t.nav.properties }}</a></li>
      <li><a href="/portfolio" data-i18n="nav.portfolio">{{ t.nav.portfolio | default('Portfolio') }}</a></li>
      <li><a href="#contact" data-i18n="nav.contact">{{ t.nav.contact }}</a></li>
    </ul>

    <div class="nav-actions">
      {# Language Toggle — margin-inline-end flips automatically in RTL #}
      <a href="/api/set-lang?lang={{ langToggle.switchTo }}&redirect={{ currentPath or '/' }}"
         class="lang-toggle" title="{{ langToggle.text }}"
         style="margin-inline-end: 8px;">
        <img src="{{ langToggle.flag }}" alt="{{ langToggle.text }}">
      </a>

      {# Theme Toggle #}
      <button type="button" id="themeToggle" title="{{ t.nav.toggleTheme }}" aria-label="{{ t.nav.toggleTheme }}" style="background: transparent; border: none; box-shadow: none; outline: none; cursor: pointer; padding: 6px; display: flex; align-items: center; justify-content: center; color: var(--text-primary);">
        <!-- Icon injected by JS -->
      </button>

      <a href="/login" class="btn btn-outline btn-sm" data-i18n="nav.signIn">{{ t.nav.signIn }}</a>
      <a href="/register" class="btn btn-primary btn-sm" data-i18n="nav.getStarted">{{ t.nav.getStarted }}</a>

      <button type="button" class="nav-toggle" id="navToggle" aria-label="{{ t.nav.toggleMenu }}">
        <i class="fas fa-bars" aria-hidden="true"></i>
      </button>
    </div>
  </div>
</nav>

{# ── Mobile Menu ── #}
<div class="mobile-menu" id="mobileMenu">
  <button type="button" class="close-btn" id="mobileClose" aria-label="Close mobile menu"><i class="fas fa-times" aria-hidden="true"></i></button>
  <a href="#home" data-i18n="nav.home">{{ t.nav.home }}</a>
  <a href="#about" data-i18n="nav.about">{{ t.nav.about }}</a>
  <a href="#services" data-i18n="nav.services">{{ t.nav.services }}</a>
  <a href="#exhibitions" style="display:inline-flex;align-items:center;gap:6px;">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
      <line x1="16" y1="2" x2="16" y2="6"></line>
      <line x1="8" y1="2" x2="8" y2="6"></line>
      <line x1="3" y1="10" x2="21" y2="10"></line>
      <path d="M8 14h.01"></path><path d="M12 14h.01"></path><path d="M16 14h.01"></path>
      <path d="M8 18h.01"></path><path d="M12 18h.01"></path><path d="M16 18h.01"></path>
    </svg>
    <span data-i18n="nav.exhibitions">{{ t.nav.exhibitions }}</span>
  </a>
  <a href="#jobs" data-i18n="nav.properties">{{ t.nav.properties }}</a>
  <a href="/portfolio" data-i18n="nav.portfolio">{{ t.nav.portfolio | default('Portfolio') }}</a>
  <a href="#contact" data-i18n="nav.contact">{{ t.nav.contact }}</a>
  <a href="/login" class="btn btn-outline" data-i18n="nav.signIn">{{ t.nav.signIn }}</a>
  <a href="/register" class="btn btn-primary" data-i18n="nav.getStarted">{{ t.nav.getStarted }}</a>
</div>
