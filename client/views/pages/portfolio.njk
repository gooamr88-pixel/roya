{# ═══════════════════════════════════════════════ #}
{# Portfolio Listing Page                           #}
{# ═══════════════════════════════════════════════ #}
{% extends "layouts/landing.njk" %}

{% set pageTitle = t.portfolio.label %}

{% block pageCss %}
  <link rel="stylesheet" href="/css/landing.css?v=6">
  <style>
    /* Portfolio specific overrides */
    .portfolio-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 32px;
      margin-top: 48px;
    }
    
    .portfolio-card {
      background: var(--bg-card);
      border: 1px solid var(--border-color);
      border-radius: var(--card-radius);
      overflow: hidden;
      transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      position: relative;
    }
    
    .portfolio-card:hover {
      transform: translateY(-8px);
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
      border-color: rgba(212, 175, 55, 0.4);
    }
    
    .portfolio-card-image {
      width: 100%;
      height: 260px;
      position: relative;
      overflow: hidden;
      background: var(--bg-secondary);
    }
    
    .portfolio-card-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.6s ease;
    }
    
    .portfolio-card:hover .portfolio-card-image img {
      transform: scale(1.08);
    }
    
    .portfolio-card-image::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(0,0,0,0.8), transparent);
      opacity: 0.6;
    }
    
    .portfolio-card-body {
      padding: 24px;
      position: relative;
      z-index: 2;
    }
    
    .portfolio-card-body h3 {
      font-size: 1.25rem;
      margin-bottom: 8px;
      color: #fff;
    }
    
    .portfolio-card-body p {
      font-size: 0.9rem;
      color: var(--text-muted);
      display: -webkit-box;
      -webkit-line-clamp: 2;
      line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .portfolio-category-badge {
      position: absolute;
      top: 16px;
      right: 16px;
      background: rgba(10, 10, 15, 0.75);
      backdrop-filter: blur(8px);
      padding: 6px 14px;
      border-radius: 30px;
      font-size: 0.75rem;
      font-weight: 600;
      color: var(--accent-primary);
      border: 1px solid rgba(212, 175, 55, 0.3);
      z-index: 3;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
  </style>
{% endblock %}

{% block content %}
  {# ════════════ PAGE HEADER ════════════ #}
  <section style="padding: 140px 0 60px; background: radial-gradient(circle at top, rgba(212, 175, 55, 0.05) 0%, transparent 50%); relative; overflow: hidden;">
    <div class="container text-center">
      <span class="section-label" style="margin-bottom: 16px;">{{ t.portfolio.label }}</span>
      <h1 class="section-title" style="font-size: 2.8rem; margin-bottom: 24px;">{{ t.portfolio.title_before }} <span class="text-gradient">{{ t.portfolio.title_highlight }}</span></h1>
      <p class="section-desc" style="margin: 0 auto; max-width: 600px; font-size: 1.15rem;">{{ t.portfolio.desc }}</p>
    </div>
  </section>

  {# ════════════ PORTFOLIO LISTING ════════════ #}
  <section style="padding-bottom: 80px;">
    <div class="container">
      <div class="portfolio-grid" id="portfolioGridPage">
        <div style="grid-column: 1/-1; padding: 60px 0; text-align: center;">
          <i class="fas fa-circle-notch fa-spin" style="font-size: 2rem; color: var(--accent-primary);"></i>
        </div>
      </div>
      <div class="text-center" style="margin-top: 48px;" id="portfolioPagination"></div>
    </div>
  </section>
{% endblock %}

{% block pageScripts %}
  <script defer>
    const P_LIMIT = 12;
    document.addEventListener('DOMContentLoaded', () => { loadPortfolioPage(1); });

    async function loadPortfolioPage(page) {
      const grid  = document.getElementById('portfolioGridPage');
      const pagEl = document.getElementById('portfolioPagination');
      
      try {
        const res  = await fetch(`/api/portfolio?page=${page}&limit=${P_LIMIT}`);
        const data = await res.json();
        
        if (!res.ok || !data.data?.items?.length) {
          const noWorksText = typeof i18n !== 'undefined' ? i18n.t('No previous works available at the moment.', 'لا توجد أعمال سابقة متاحة في الوقت الحالي') : 'No works found.';
          grid.innerHTML = \`<div class="empty-state" style="grid-column: 1/-1; padding: 60px 0;">
            <div class="icon" style="font-size: 3rem; color: var(--text-muted); margin-bottom: 16px;"><i class="fas fa-folder-open"></i></div>
            <h3 style="color: var(--text-secondary);">\${noWorksText}</h3>
          </div>\`;
          pagEl.innerHTML = '';
          return;
        }

        const items = data.data.items;
        const pagination = data.data.pagination;

        grid.innerHTML = items.map(item => {
          let imageUrl = '/images/placeholder.jpg';
          if (item.images) {
             try {
                const parsed = typeof item.images === 'string' ? JSON.parse(item.images) : item.images;
                if (Array.isArray(parsed) && parsed.length > 0) imageUrl = parsed[0];
             } catch(e) {}
          }
           
          return \`
            <div class="portfolio-card fade-in visible">
              <div class="portfolio-category-badge">\${esc(item.category || 'General')}</div>
              <div class="portfolio-card-image">
                <img src="\${esc(imageUrl)}" alt="\${esc(item.title)}" loading="lazy">
              </div>
              <div class="portfolio-card-body">
                <h3>\${esc(item.title)}</h3>
                \${item.description ? \`<p>\${esc(item.description)}</p>\` : ''}
              </div>
            </div>\`;
        }).join('');

        // Basic Pagination
        if (pagination && pagination.totalPages > 1) {
          let btns = '';
          for (let i = 1; i <= pagination.totalPages; i++) {
            btns += \`<button class="btn \${i === page ? 'btn-primary' : 'btn-outline'} btn-sm" style="margin: 0 4px;" data-page="\${i}">\${i}</button>\`;
          }
          pagEl.innerHTML = btns;
          pagEl.querySelectorAll('[data-page]').forEach(btn => {
            btn.addEventListener('click', () => {
                grid.innerHTML = '<div style="grid-column: 1/-1; padding: 60px 0; text-align: center;"><i class="fas fa-circle-notch fa-spin" style="font-size: 2rem; color: var(--accent-primary);"></i></div>';
                loadPortfolioPage(parseInt(btn.dataset.page));
            });
          });
        } else { 
            pagEl.innerHTML = ''; 
        }
        
      } catch (err) {
        grid.innerHTML = \`<div class="empty-state" style="grid-column: 1/-1; padding: 60px 0;">
           <div class="icon" style="color: var(--danger);"><i class="fas fa-exclamation-triangle"></i></div>
           <h3>Failed to load portfolio items.</h3>
        </div>\`;
      }
    }
    
    // Minimal HTML escape utility for dynamic rendering
    function esc(str) {
      if (!str) return '';
      return String(str).replace(/[&<>"']/g, function(m) {
        return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[m];
      });
    }
  </script>
{% endblock %}
