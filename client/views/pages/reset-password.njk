{# ═══════════════════════════════════════════════ #}
{# Reset Password Page                              #}
{# ═══════════════════════════════════════════════ #}
{% extends "layouts/base.njk" %}

{% set pageTitle = t.resetPassword.title %}

{% block pageCss %}
  <link rel="stylesheet" href="/css/auth.css">
{% endblock %}

{% block body %}
  <div class="auth-page">
    <div class="auth-brand">
      <div class="auth-brand-content">
        <div class="auth-brand-logo">
          <img class="logo-for-dark" src="/images/nabda-logo-transparent.svg" alt="{{ logoAlt }}" style="height:56px;width:auto;object-fit:contain;">
          <img class="logo-for-light" src="/images/nabda-logo-dark.svg" alt="{{ logoAlt }}" style="height:56px;width:auto;object-fit:contain;">
        </div>
        <h2 data-i18n="resetPassword.welcome">{{ t.resetPassword.welcome }}</h2>
        <p data-i18n="resetPassword.welcomeDesc">{{ t.resetPassword.welcomeDesc }}</p>
      </div>
    </div>

    <div class="auth-form-side">
      <div class="auth-form-wrapper">
        <a href="/login" class="back-link"><i class="fas fa-arrow-left back-arrow-icon"></i> <span data-i18n="resetPassword.backToLogin">{{ t.resetPassword.backToLogin }}</span></a>

        <div style="display:flex;align-items:center;gap:10px;margin-bottom:20px;">
          <img class="logo-for-dark" src="/images/nabda-logo-transparent.svg" alt="{{ logoAlt }}" style="height:40px;width:auto;object-fit:contain;">
          <img class="logo-for-light" src="/images/nabda-logo-dark.svg" alt="{{ logoAlt }}" style="height:40px;width:auto;object-fit:contain;">
        </div>

        {# Steps indicator #}
        <div class="auth-steps" id="resetSteps">
          <div class="auth-step active"></div>
          <div class="auth-step"></div>
          <div class="auth-step"></div>
        </div>

        {# Step 1: Request Reset #}
        <div id="resetStep1">
          <h1 data-i18n="resetPassword.heading">{{ t.resetPassword.heading }}</h1>
          <p class="subtitle" data-i18n="resetPassword.subtitle">{{ t.resetPassword.subtitle }}</p>

          <form id="resetRequestForm">
            <div class="form-group">
              <label class="form-label" for="email" data-i18n="resetPassword.emailLabel">{{ t.resetPassword.emailLabel }}</label>
              <input class="form-input" type="email" id="email" placeholder="{{ t.resetPassword.emailPlaceholder }}" data-i18n="resetPassword.emailPlaceholder" required>
            </div>
            <button type="submit" class="btn btn-primary btn-lg w-full" id="resetRequestBtn">
              <i class="fas fa-paper-plane"></i> <span data-i18n="resetPassword.sendBtn">{{ t.resetPassword.sendBtn }}</span>
            </button>
          </form>
        </div>

        {# Step 2: OTP Verification #}
        <div id="resetStep2" class="hidden">
          <h1 data-i18n="register.otpHeading">{{ t.register.otpHeading | default('Enter Reset Code') }}</h1>
          <p class="subtitle"><span data-i18n="register.otpSubtitle">{{ t.register.otpSubtitle | default('We sent a 6-digit code to') }}</span> <strong id="resetOtpEmail"></strong></p>

          <form id="resetOtpForm">
            <div class="otp-container" id="resetOtpContainer">
              <input class="otp-input" type="text" maxlength="1" data-index="0" autocomplete="off">
              <input class="otp-input" type="text" maxlength="1" data-index="1" autocomplete="off">
              <input class="otp-input" type="text" maxlength="1" data-index="2" autocomplete="off">
              <input class="otp-input" type="text" maxlength="1" data-index="3" autocomplete="off">
              <input class="otp-input" type="text" maxlength="1" data-index="4" autocomplete="off">
              <input class="otp-input" type="text" maxlength="1" data-index="5" autocomplete="off">
            </div>

            <button type="submit" class="btn btn-primary btn-lg w-full" id="resetVerifyBtn">
              <i class="fas fa-check-circle"></i> <span data-i18n="register.verifyBtn">{{ t.register.verifyBtn | default('Verify Code') }}</span>
            </button>
          </form>
          
          <div class="otp-timer">
            <span data-i18n="register.noCode">{{ t.register.noCode | default('Didn\'t receive a code?') }}</span> <button class="btn btn-ghost btn-sm" id="resetResendBtn" disabled><span data-i18n="register.resendIn">{{ t.register.resendIn | default('Resend in') }}</span> <strong id="resetTimer">60</strong>s</button>
          </div>
        </div>

        {# Step 3: New Password #}
        <div id="resetStep3" class="hidden">
          <h1 data-i18n="resetPassword.newHeading">{{ t.resetPassword.newHeading }}</h1>
          <p class="subtitle" data-i18n="resetPassword.newSubtitle">{{ t.resetPassword.newSubtitle }}</p>

          <form id="newPasswordForm">
            <div class="form-group">
              <label class="form-label" for="newPass" data-i18n="resetPassword.newPassLabel">{{ t.resetPassword.newPassLabel }}</label>
              <div class="password-toggle">
                <input class="form-input" type="password" id="newPass" placeholder="{{ t.resetPassword.newPassPlaceholder }}" data-i18n="resetPassword.newPassPlaceholder" required>
                <button type="button" class="toggle-btn" onclick="togglePassword('newPass', this)">
                  <i class="fas fa-eye"></i>
                </button>
              </div>
            </div>
            <div class="form-group">
              <label class="form-label" for="confirmNewPass" data-i18n="resetPassword.confirmLabel">{{ t.resetPassword.confirmLabel }}</label>
              <input class="form-input" type="password" id="confirmNewPass" placeholder="{{ t.resetPassword.confirmPlaceholder }}" data-i18n="resetPassword.confirmPlaceholder" required>
            </div>
            <button type="submit" class="btn btn-primary btn-lg w-full" id="newPasswordBtn">
              <i class="fas fa-lock"></i> <span data-i18n="resetPassword.resetBtn">{{ t.resetPassword.resetBtn }}</span>
            </button>
          </form>
        </div>

        <div style="text-align: center; margin-top: 12px;">
          <a href="/api/set-lang?lang={{ langToggle.switchTo }}&redirect=/reset-password" class="lang-toggle"
             title="{{ langToggle.text }}" style="display:inline-block;">
            <img src="{{ langToggle.flag }}" alt="{{ langToggle.text }}">
          </a>
        </div>

        <p class="auth-footer">
          <span data-i18n="resetPassword.rememberPassword">{{ t.resetPassword.rememberPassword }}</span> <a href="/login" data-i18n="resetPassword.signIn">{{ t.resetPassword.signIn }}</a>
        </p>
      </div>
    </div>
  </div>
{% endblock %}

{% block pageScripts %}
  <script src="/js/auth.js" defer></script>
{% endblock %}
