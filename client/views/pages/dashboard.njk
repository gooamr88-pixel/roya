{# ═══════════════════════════════════════════════ #}
{# Dashboard V2.0 — User Control Center           #}
{# Uses base layout (own sidebar, no shared navbar) #}
{# ═══════════════════════════════════════════════ #}
{% extends "layouts/base.njk" %}

{% set pageTitle = t.dashboard.title %}

{% block pageCss %}
  <link rel="stylesheet" href="/css/dashboard.css">
  <link rel="stylesheet" href="/css/onboarding.css">
{% endblock %}

{% block body %}
  <div class="dashboard-layout">

    {# ════════════ SIDEBAR ════════════ #}
    <aside class="sidebar" id="sidebar">
      <div class="sidebar-header">
        <a href="/" class="sidebar-logo">
          <img class="logo-for-dark" src="/images/nabda-logo-transparent.svg" alt="{{ logoAlt }}" style="height:44px;width:auto;object-fit:contain;">
          <img class="logo-for-light" src="/images/nabda-logo-dark.svg" alt="{{ logoAlt }}" style="height:44px;width:auto;object-fit:contain;">
          {% if brandNameIsImage %}
            <img src="{{ brandNameSrc }}" alt="{{ logoAlt }}" class="brand-name-img" style="height:24px;width:auto;">
          {% else %}
            <span class="brand-name brand-name-sm">{{ logoAlt }}</span>
          {% endif %}
        </a>
        <button type="button" class="sidebar-close" id="sidebarClose" aria-label="{{ t.dashboard.closeSidebar | default('Close Sidebar') }}"><i class="fas fa-times" aria-hidden="true"></i></button>
      </div>

      <nav class="sidebar-nav">
        <div class="nav-section">{{ t.dashboard.navMain }}</div>
        <button class="sidebar-link active" data-view="overview">
          <span class="icon"><i class="fas fa-th-large"></i></span> {{ t.dashboard.overview }}
          <span class="kbd-hint">1</span>
        </button>
        <button class="sidebar-link" data-view="orders">
          <span class="icon"><i class="fas fa-shopping-bag"></i></span> {{ t.dashboard.myOrders }}
          <span class="badge-count hidden" id="ordersCount">0</span>
          <span class="kbd-hint">2</span>
        </button>
        <button class="sidebar-link" data-view="services">
          <span class="icon"><i class="fas fa-concierge-bell"></i></span> {{ t.dashboard.browseServices }}
          <span class="kbd-hint">3</span>
        </button>
        <button class="sidebar-link" data-view="exhibitions">
          <span class="icon" style="display:flex;align-items:center;justify-content:center;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
              <line x1="16" y1="2" x2="16" y2="6"></line>
              <line x1="8" y1="2" x2="8" y2="6"></line>
              <line x1="3" y1="10" x2="21" y2="10"></line>
              <path d="M8 14h.01"></path><path d="M12 14h.01"></path><path d="M16 14h.01"></path>
              <path d="M8 18h.01"></path><path d="M12 18h.01"></path><path d="M16 18h.01"></path>
            </svg>
          </span>
          {{ t.nav.exhibitions | default('Exhibitions') }}
          <span class="kbd-hint">4</span>
        </button>

        <div class="nav-section">{{ t.dashboard.navAccount }}</div>
        <button class="sidebar-link" data-view="notifications">
          <span class="icon"><i class="fas fa-bell"></i></span> {{ t.dashboard.notifications }}
          <span class="badge-count hidden" id="notifCount">0</span>
          <span class="kbd-hint">5</span>
        </button>
        <button class="sidebar-link" data-view="invoices">
          <span class="icon"><i class="fas fa-file-invoice-dollar"></i></span> {{ t.dashboard.myInvoices }}
          <span class="kbd-hint">6</span>
        </button>
        <button class="sidebar-link" data-view="profile">
          <span class="icon"><i class="fas fa-user-cog"></i></span> {{ t.dashboard.profile }}
          <span class="kbd-hint">7</span>
        </button>
      </nav>

      <div class="sidebar-footer">
        <div class="sidebar-user">
          <div class="avatar" id="userAvatar">U</div>
          <div>
            <div class="name" id="userName">{{ t.dashboard.userDefault }}</div>
            <div class="role" id="userRole">{{ t.dashboard.roleDefault }}</div>
          </div>
        </div>
      </div>
    </aside>
    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    {# ════════════ MAIN CONTENT ════════════ #}
    <div class="main-content">
      {# Top Bar #}
      <div class="topbar">
        <div class="topbar-left">
          <button type="button" class="sidebar-toggle" id="sidebarToggle" aria-label="Toggle Sidebar"><i class="fas fa-bars" aria-hidden="true"></i></button>
          <div class="topbar-title">
            <h1 id="viewTitle" style="font-size: 1.5rem; margin: 0; color: var(--text-1);">{{ t.dashboard.controlCenter }}</h1>
            <span id="viewSubtitle">{{ t.dashboard.welcomeBack }}</span>
          </div>
        </div>
        <div class="topbar-right">
          <a href="/api/set-lang?lang={{ langToggle.switchTo }}&redirect=/dashboard" class="topbar-btn" title="{{ langToggle.text }}" data-tooltip="{{ langToggle.text }}">
            <img src="{{ langToggle.flag }}" alt="{{ langToggle.text }}" style="width:18px;height:auto;border-radius:2px;">
          </a>
          <button type="button" class="topbar-btn" id="themeToggle" title="{{ t.nav.toggleTheme }}" aria-label="{{ t.nav.toggleTheme }}" data-tooltip="{{ t.nav.toggleTheme }}" style="background: transparent; border: none; box-shadow: none; outline: none; padding: 6px; display: flex; align-items: center; justify-content: center; color: var(--text-primary);">
            <!-- Icon injected by JS -->
          </button>
          <button type="button" class="topbar-btn" title="{{ t.dashboard.notifications }}" aria-label="{{ t.dashboard.notifications }}" data-view="notifications" data-tooltip="{{ t.dashboard.notifications }}">
            <i class="fas fa-bell" aria-hidden="true"></i>
            <span class="notif-dot hidden" id="notifDot"></span>
          </button>
          <a href="/admin" class="topbar-btn" id="adminLink" style="display:none" title="{{ t.dashboard.adminPanel }}" aria-label="{{ t.dashboard.adminPanel }}" data-tooltip="{{ t.dashboard.adminPanel }}">
            <i class="fas fa-shield-halved" aria-hidden="true"></i>
          </a>
          <button type="button" class="topbar-btn" title="{{ t.dashboard.logout }}" id="logoutBtn" aria-label="{{ t.dashboard.logout }}" data-tooltip="{{ t.dashboard.logout }}"><i class="fas fa-sign-out-alt" aria-hidden="true"></i></button>
        </div>
      </div>

      {# Breadcrumb #}
      <div class="breadcrumb-strip" id="breadcrumb">
        <a href="/"><i class="fas fa-home"></i></a>
        <span class="separator">/</span>
        <span class="current" id="breadcrumbCurrent">{{ t.dashboard.overview }}</span>
      </div>

      {# Content Area #}
      <div class="content-area">

        {# ── OVERVIEW ── #}
        <div class="view-section active" id="view-overview">
          <div class="stats-grid" id="statsGrid">
            <div class="stat-card">
              <div class="stat-header">
                <div class="stat-icon purple"><i class="fas fa-shopping-bag"></i></div>
                <div class="stat-label">{{ t.dashboard.activeOrders }}</div>
              </div>
              <div class="stat-value" id="statOrders"><div class="skeleton skeleton-value"></div></div>
            </div>
            <div class="stat-card">
              <div class="stat-header">
                <div class="stat-icon green"><i class="fas fa-check-circle"></i></div>
                <div class="stat-label">{{ t.dashboard.completed }}</div>
              </div>
              <div class="stat-value" id="statCompleted"><div class="skeleton skeleton-value"></div></div>
            </div>
            <div class="stat-card">
              <div class="stat-header">
                <div class="stat-icon orange"><i class="fas fa-wallet"></i></div>
                <div class="stat-label">{{ t.dashboard.totalSpent }}</div>
              </div>
              <div class="stat-value" id="statSpent"><div class="skeleton skeleton-value"></div></div>
            </div>
            <div class="stat-card">
              <div class="stat-header">
                <div class="stat-icon blue"><i class="fas fa-bell"></i></div>
                <div class="stat-label">{{ t.dashboard.notifications }}</div>
              </div>
              <div class="stat-value" id="statNotifications"><div class="skeleton skeleton-value"></div></div>
            </div>
          </div>

          <div style="display:flex;gap:12px;margin-bottom:32px;flex-wrap:wrap;">
            <button class="btn btn-primary btn-sm" data-view="services">
              <i class="fas fa-plus"></i> {{ t.dashboard.newOrder }}
            </button>
            <button class="btn btn-outline btn-sm" data-view="invoices">
              <i class="fas fa-file-invoice"></i> {{ t.dashboard.myInvoices }}
            </button>
            <button class="btn btn-outline btn-sm" data-view="notifications">
              <i class="fas fa-bell"></i> {{ t.dashboard.notifications }}
            </button>
          </div>

          {# ── Recommended For You ── #}
          <div class="recommendations-section" id="aiRecommendations" style="display:none"></div>

          <div class="dashboard-card full-width" style="margin-bottom:32px">
            <div class="card-header">
              <h3><i class="fas fa-route"></i> {{ t.dashboard.activeOrderProgress }}</h3>
            </div>
            <div id="orderTimeline">
              <div style="padding:32px;text-align:center;color:var(--text-muted)">
                <i class="fas fa-clock" style="font-size:2rem;display:block;margin-bottom:10px"></i>
                {{ t.dashboard.noActiveOrders }}
              </div>
            </div>
          </div>

          <div class="dashboard-card full-width">
            <div class="card-header">
              <h3><i class="fas fa-history"></i> {{ t.dashboard.recentOrders }}</h3>
              <button class="btn btn-outline btn-sm" data-view="orders">{{ t.dashboard.viewAll }}</button>
            </div>
            <div class="table-container">
              <table class="data-table">
                <thead>
                  <tr>
                    <th>{{ t.dashboard.thInvoice }}</th>
                    <th>{{ t.dashboard.thService }}</th>
                    <th>{{ t.dashboard.thAmount }}</th>
                    <th>{{ t.dashboard.thStatus }}</th>
                    <th>{{ t.dashboard.thDate }}</th>
                  </tr>
                </thead>
                <tbody id="recentOrdersTable">
                  <tr><td colspan="5"><div class="skeleton skeleton-row"></div></td></tr>
                  <tr><td colspan="5"><div class="skeleton skeleton-row"></div></td></tr>
                  <tr><td colspan="5"><div class="skeleton skeleton-row"></div></td></tr>
                </tbody>
              </table>
            </div>
          </div>
        </div>

        <div class="view-section" id="view-orders">
          <div class="filters-bar">
            <select class="form-select" id="orderStatusFilter">
              <option value="">{{ t.dashboard.allStatuses }}</option>
              <option value="pending">{{ t.dashboard.pending }}</option>
              <option value="in_progress">{{ t.dashboard.inProgress }}</option>
              <option value="completed">{{ t.dashboard.completedStatus }}</option>
              <option value="cancelled">{{ t.dashboard.cancelled }}</option>
            </select>
          </div>
          <div class="order-cards-grid" id="ordersTable"></div>
          <div class="pagination" id="ordersPagination"></div>
        </div>

        {# ── SERVICES ── #}
        <div class="view-section" id="view-services">
          <div class="services-grid" id="dashServicesGrid">
            <div class="skeleton skeleton-card"></div>
            <div class="skeleton skeleton-card"></div>
            <div class="skeleton skeleton-card"></div>
          </div>
        </div>

        {# ── EXHIBITIONS ── #}
        <div class="view-section" id="view-exhibitions">
          <div class="exhibitions-grid" id="dashExhibitionsGrid">
            <div class="skeleton skeleton-card"></div>
            <div class="skeleton skeleton-card"></div>
          </div>
        </div>

        {# ── NOTIFICATIONS ── #}
        <div class="view-section" id="view-notifications">
          <div style="display:flex;justify-content:flex-end;margin-bottom:16px">
            <button class="btn btn-ghost btn-sm" id="markAllReadBtn"><i class="fas fa-check-double"></i> {{ t.dashboard.markAllRead }}</button>
          </div>
          <div id="notificationsList"></div>
          <div class="pagination" id="notifPagination"></div>
        </div>

        {# ── INVOICES ── #}
        <div class="view-section" id="view-invoices">
          <div class="table-container">
            <table class="data-table">
              <thead>
                <tr>
                  <th>{{ t.dashboard.thInvoice }}</th>
                  <th>{{ t.dashboard.thService }}</th>
                  <th>{{ t.dashboard.thTotal }}</th>
                  <th>{{ t.dashboard.thStatus }}</th>
                  <th>{{ t.dashboard.thDate }}</th>
                  <th>{{ t.dashboard.thActions }}</th>
                </tr>
              </thead>
              <tbody id="invoicesTable"></tbody>
            </table>
          </div>
          <div class="pagination" id="invoicesPagination"></div>
        </div>

        {# ── PROFILE ── #}
        <div class="view-section" id="view-profile">
          <div class="profile-header">
            <div class="profile-avatar" id="profileAvatar">U</div>
            <div class="profile-info">
              <h2 id="profileName">{{ t.dashboard.userDefault }}</h2>
              <p class="email" id="profileEmail">user@example.com</p>
            </div>
          </div>

          <div class="dashboard-grid" style="margin-top:24px">
            <div class="dashboard-card">
              <div class="card-header">
                <h3><i class="fas fa-user-edit"></i> {{ t.dashboard.personalInfo }}</h3>
              </div>
              <form id="profileForm">
                <div class="profile-form-grid">
                  <div class="form-group">
                    <label class="form-label" for="profileNameInput">{{ t.dashboard.fullName }}</label>
                    <input class="form-input" type="text" id="profileNameInput">
                  </div>
                  <div class="form-group">
                    <label class="form-label" for="profilePhoneInput">{{ t.dashboard.phone }} <span class="help-tooltip">?<span class="tooltip-text">{{ t.dashboard.tooltipPhone | default('Your phone number for order updates and support. Include country code.') }}</span></span></label>
                    <input class="form-input" type="tel" id="profilePhoneInput">
                  </div>
                </div>
                <button type="submit" class="btn btn-primary mt-2"><i class="fas fa-save"></i> {{ t.dashboard.saveChanges }}</button>
              </form>
            </div>

            <div class="dashboard-card">
              <div class="card-header">
                <h3><i class="fas fa-lock"></i> {{ t.dashboard.changePassword }} <span class="help-tooltip">?<span class="tooltip-text">{{ t.dashboard.tooltipPassword | default('Minimum 8 characters. Use upper-case, numbers, and symbols for better security.') }}</span></span></h3>
              </div>
              <form id="changePasswordForm">
                <div class="form-group">
                  <label class="form-label" for="currentPass">{{ t.dashboard.currentPassword }}</label>
                  <input class="form-input" type="password" id="currentPass" placeholder="{{ t.dashboard.currentPasswordPlaceholder }}" required>
                </div>
                <div class="form-group">
                  <label class="form-label" for="newPass">{{ t.dashboard.newPassword }}</label>
                  <input class="form-input" type="password" id="newPass" placeholder="{{ t.dashboard.newPasswordPlaceholder }}" required>
                </div>
                <div class="form-group">
                  <label class="form-label" for="confirmNewPass">{{ t.dashboard.confirmNewPassword }}</label>
                  <input class="form-input" type="password" id="confirmNewPass" placeholder="{{ t.dashboard.confirmNewPasswordPlaceholder }}" required>
                </div>
                <button type="submit" class="btn btn-primary mt-2"><i class="fas fa-key"></i> {{ t.dashboard.updatePassword }}</button>
              </form>
            </div>
          </div>
        </div>

      </div>{# /.content-area #}
    </div>{# /.main-content #}
  </div>{# /.dashboard-layout #}

  {# ═════ FROSTED GLASS CONFIRMATION MODAL ═════ #}
  {% include "partials/glass-confirm.njk" %}

  {# ═════ AI PROMPT MODAL ═════ #}
  <div class="ai-modal-overlay" id="aiModalOverlay">
    <div class="ai-modal">
      <div class="ai-modal-header">
        <h3><i class="fas fa-wand-magic-sparkles"></i> <span id="aiModalTitle">{{ t.dashboard.aiPromptTitle | default('AI Content Assistant') }}</span></h3>
        <button class="ai-modal-close" onclick="closeAiModal()">&times;</button>
      </div>
      <div class="ai-modal-body">
        <div style="position:relative">
          <textarea id="aiPromptInput" rows="3" placeholder="{{ t.dashboard.aiPromptPlaceholder | default('E.g., I want an ad campaign for a new real estate app targeting young professionals...') }}"></textarea>
          <span class="help-tooltip" style="position:absolute;top:8px;right:8px;z-index:2">?<span class="tooltip-text">{{ t.dashboard.aiTooltipDetail | default('Tip: The more details you provide (audience, tone, platform), the better the AI result will be.') }}</span></span>
        </div>
        <div class="ai-modal-hint" id="aiModalHint">{{ t.dashboard.aiPromptHint | default('AI will generate a professional description based on your idea.') }}</div>
        <div class="ai-modal-actions">
          <button class="btn btn-outline btn-sm" onclick="closeAiModal()">{{ t.dashboard.cancel | default('Cancel') }}</button>
          <button class="btn-ai-generate" id="aiGenerateBtn" onclick="aiGenerate()">
            <span class="btn-text"><i class="fas fa-wand-magic-sparkles"></i> {{ t.dashboard.aiGenerate | default('Generate') }}</span>
            <span class="ai-spinner"></span>
          </button>
        </div>
      </div>
    </div>
  </div>
{% endblock %}

{% block pageScripts %}
  <script>
    window.__dt = {
      greetingMorning:      '{{ t.dashboard.greetingMorning | default("Good morning") }}',
      greetingAfternoon:    '{{ t.dashboard.greetingAfternoon | default("Good afternoon") }}',
      greetingEvening:      '{{ t.dashboard.greetingEvening | default("Good evening") }}',
      roleDefault:          '{{ t.dashboard.roleDefault | default("Client") }}',
      controlCenter:        '{{ t.dashboard.controlCenter | default("Control Center") }}',
      myOrders:             '{{ t.dashboard.myOrders | default("My Orders") }}',
      browseServices:       '{{ t.dashboard.browseServices | default("Browse Services") }}',
      exhibitions:          '{{ t.dashboard.exhibitions | default("Exhibitions") }}',
      notifications:        '{{ t.dashboard.notifications | default("Notifications") }}',
      myInvoices:           '{{ t.dashboard.myInvoices | default("My Invoices") }}',
      profileSettings:      '{{ t.dashboard.profileSettings | default("Profile Settings") }}',
      justNow:              '{{ t.dashboard.justNow | default("Just now") }}',
      minutesAgo:           '{{ t.dashboard.minutesAgo | default("m ago") }}',
      hoursAgo:             '{{ t.dashboard.hoursAgo | default("h ago") }}',
      daysAgo:              '{{ t.dashboard.daysAgo | default("d ago") }}',
      noOrdersYet:          '{{ t.dashboard.noOrdersYet | default("No orders yet") }}',
      noOrdersFound:        '{{ t.dashboard.noOrdersFound | default("No orders found") }}',
      noInvoicesYet:        '{{ t.dashboard.noInvoicesYet | default("No invoices yet") }}',
      noNotifications:      '{{ t.dashboard.noNotifications | default("No notifications") }}',
      allCaughtUp:          '{{ t.dashboard.allCaughtUp | default("You\'re all caught up!") }}',
      noExhibitions:        '{{ t.dashboard.noExhibitions | default("No exhibitions") }}',
      checkBackExhibitions: '{{ t.dashboard.checkBackExhibitions | default("Check back soon for upcoming events.") }}',
      active:               '{{ t.dashboard.active | default("Active") }}',
      past:                 '{{ t.dashboard.past | default("Past") }}',
      timeline:             '{{ t.dashboard.timeline | default("Timeline") }}',
      viewTimeline:         '{{ t.dashboard.viewTimeline | default("View Timeline") }}',
      cancel:               '{{ t.dashboard.cancel | default("Cancel") }}',
      cancelOrder:          '{{ t.dashboard.cancelOrder | default("Cancel Order") }}',
      cancelOrderConfirm:   '{{ t.dashboard.cancelOrderConfirm | default("Cancel order #%s? This cannot be undone.") }}',
      orderCancelled:       '{{ t.dashboard.orderCancelled | default("Order cancelled successfully.") }}',
      failedCancelOrder:    '{{ t.dashboard.failedCancelOrder | default("Failed to cancel order.") }}',
      orderPlaced:          '{{ t.dashboard.orderPlaced | default("Order placed successfully!") }}',
      request:              '{{ t.dashboard.request | default("Request") }}',
      profileUpdated:       '{{ t.dashboard.profileUpdated | default("Profile updated!") }}',
      passwordChanged:      '{{ t.dashboard.passwordChanged | default("Password changed successfully!") }}',
      fillPasswordFields:   '{{ t.dashboard.fillPasswordFields | default("Please fill in all password fields.") }}',
      passwordsNotMatch:    '{{ t.dashboard.passwordsNotMatch | default("New passwords do not match.") }}',
      passwordMinLength:    '{{ t.dashboard.passwordMinLength | default("Password must be at least 8 characters.") }}',
      saving:               '{{ t.dashboard.saving | default("Saving...") }}',
      updating:             '{{ t.dashboard.updating | default("Updating...") }}',
      allNotificationsRead: '{{ t.dashboard.allNotificationsRead | default("All notifications marked as read.") }}',
      failedLoadOrders:     '{{ t.dashboard.failedLoadOrders | default("Failed to load orders.") }}',
      failedLoadServices:   '{{ t.dashboard.failedLoadServices | default("Failed to load services.") }}',
      failedLoadExhibitions:'{{ t.dashboard.failedLoadExhibitions | default("Failed to load exhibitions.") }}',
      failedLoadNotifications:'{{ t.dashboard.failedLoadNotifications | default("Failed to load notifications.") }}',
      failedLoadInvoices:   '{{ t.dashboard.failedLoadInvoices | default("Failed to load invoices.") }}',
      statusPending:        '{{ t.dashboard.statusPending | default("Pending") }}',
      statusConfirmed:      '{{ t.dashboard.statusConfirmed | default("Confirmed") }}',
      statusInProgress:     '{{ t.dashboard.statusInProgress | default("In Progress") }}',
      statusCompleted:      '{{ t.dashboard.statusCompleted | default("Completed") }}',
      statusCancelled:      '{{ t.dashboard.statusCancelled | default("Cancelled") }}',
      thisOrderCancelled:   '{{ t.dashboard.thisOrderCancelled | default("This order has been cancelled.") }}',
      logOut:               '{{ t.dashboard.logOut | default("Log Out") }}',
      logOutConfirm:        '{{ t.dashboard.logOutConfirm | default("Are you sure you want to log out?") }}',
      confirm:              '{{ t.dashboard.confirm | default("Confirm") }}',
      noActiveOrders:       '{{ t.dashboard.noActiveOrders | default("No active orders") }}',
      emptyOrdersDesc:      '{{ t.dashboard.emptyOrdersDesc | default("Place your first order to get started with our services.") }}',
      emptyOrdersCta:       '{{ t.dashboard.emptyOrdersCta | default("Browse Services") }}',
      emptyOrdersFilterDesc:'{{ t.dashboard.emptyOrdersFilterDesc | default("Try adjusting your filters or place a new order.") }}',
      emptyInvoicesDesc:    '{{ t.dashboard.emptyInvoicesDesc | default("Invoices will appear here once you place your first order.") }}',
      tourWelcomeTitle:     '{{ t.onboarding.welcomeTitle | default("Welcome to Nabda!") }}',
      tourWelcomeDesc:      '{{ t.onboarding.welcomeDesc | default("Let us give you a quick tour of your dashboard.") }}',
      tourStatsTitle:       '{{ t.onboarding.statsTitle | default("Your Overview") }}',
      tourStatsDesc:        '{{ t.onboarding.statsDesc | default("See your active orders, completed projects, and spending at a glance.") }}',
      tourSidebarTitle:     '{{ t.onboarding.sidebarTitle | default("Navigation") }}',
      tourSidebarDesc:      '{{ t.onboarding.sidebarDesc | default("Use the sidebar to switch between orders, services, and more.") }}',
      tourServicesTitle:    '{{ t.onboarding.servicesTitle | default("Browse Services") }}',
      tourServicesDesc:     '{{ t.onboarding.servicesDesc | default("Explore our services and place orders with a single click.") }}',
      tourNotifTitle:       '{{ t.onboarding.notifTitle | default("Notifications") }}',
      tourNotifDesc:        '{{ t.onboarding.notifDesc | default("Stay updated on order status changes and important announcements.") }}',
      tourProfileTitle:     '{{ t.onboarding.profileTitle | default("Your Profile") }}',
      tourProfileDesc:      '{{ t.onboarding.profileDesc | default("Manage your personal information and security settings here.") }}',
      tourNext:             '{{ t.onboarding.next | default("Next") }}',
      tourSkip:             '{{ t.onboarding.skip | default("Skip Tour") }}',
      tourFinish:           '{{ t.onboarding.finish | default("Get Started!") }}',
      aiGenerate:           '{{ t.dashboard.aiGenerate | default("✨ AI Generate") }}',
