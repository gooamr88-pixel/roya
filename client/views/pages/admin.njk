            <input class="form-input" type="text" id="portfolioCategory" placeholder="{{ t.admin.portfolioCatPlaceholder | default('e.g. branding, events, digital') }}">
          </div>
          {# ── Arabic Content (i18n) ── #}
          <div style="border:1px dashed var(--border-color);border-radius:8px;padding:12px;margin-bottom:12px">
            <div style="font-size:0.8rem;color:var(--text-3);margin-bottom:8px"><i class="fas fa-language" style="margin-inline-end:4px"></i> {{ t.admin.arabicContent | default('Arabic Content') }}</div>
            <div class="form-group">
              <label class="form-label">{{ t.admin.titleAr | default('Arabic Title') }}</label>
              <input class="form-input" type="text" id="portfolioTitleAr" maxlength="200" dir="rtl" placeholder="{{ t.admin.titleArPlaceholder | default('العنوان بالعربية') }}">
            </div>
            <div class="form-group">
              <label class="form-label">{{ t.admin.descriptionAr | default('Arabic Description') }}</label>
              <textarea class="form-textarea" id="portfolioDescriptionAr" rows="2" dir="rtl" placeholder="{{ t.admin.descArPlaceholder | default('الوصف بالعربية') }}"></textarea>
            </div>
          </div>
          <div class="wizard-nav">
            <span></span>
            <button type="button" class="btn-wizard-next" onclick="wizardNext('portfolioWizardForm')"><span>{{ t.admin.wizardNext | default('Next') }}</span> <i class="fas fa-arrow-right"></i></button>
          </div>
        </div>

        {# Step 2: Media #}
        <div class="wizard-pane" data-wizard-pane="1">
          <div class="form-group">
            <label class="form-label">{{ t.admin.dropZoneTitle }}</label>
            <input type="file" id="portfolioImages" accept="image/*" multiple class="form-input" style="padding:10px">
            <div id="portfolioImgPreview" style="display:flex;gap:8px;flex-wrap:wrap;margin-top:8px"></div>
          </div>
          <div class="wizard-nav">
            <button type="button" class="btn-wizard-back" onclick="wizardPrev('portfolioWizardForm')"><i class="fas fa-arrow-left"></i> <span>{{ t.admin.wizardBack | default('Back') }}</span></button>
            <button type="button" class="btn-wizard-next" onclick="wizardNext('portfolioWizardForm')"><span>{{ t.admin.wizardNext | default('Next') }}</span> <i class="fas fa-arrow-right"></i></button>
          </div>
        </div>

        {# Step 3: Publish #}
        <div class="wizard-pane" data-wizard-pane="2">
          <div class="form-group" style="display:flex;align-items:center;gap:10px">
            <input type="checkbox" id="portfolioIsActive" checked style="width:18px;height:18px;cursor:pointer">
            <label for="portfolioIsActive" class="form-label" style="margin:0;cursor:pointer">{{ t.admin.activeStatus }} <span class="help-tooltip">?<span class="tooltip-text">{{ t.admin.tooltipActiveVisible | default('When unchecked, this item will be hidden from all public-facing pages.') }}</span></span></label>
          </div>
          <div class="wizard-nav">
            <button type="button" class="btn-wizard-back" onclick="wizardPrev('portfolioWizardForm')"><i class="fas fa-arrow-left"></i> <span>{{ t.admin.wizardBack | default('Back') }}</span></button>
            <button type="submit" class="btn btn-primary" style="gap:8px"><i class="fas fa-save"></i> {{ t.admin.savePortfolio }}</button>
          </div>
        </div>
      </form>
    </div>
  </div>

