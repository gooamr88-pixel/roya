{# Base Layout Гўв‚¬вЂќ Shared by ALL pages              #}
{# Variables injected by i18n middleware:          #}
{#   lang, dir, isRTL, t, logoSrc, logoAlt,       #}
{#   langToggle, baseUrl                           #}
{# Each page sets: pageTitle, pageDescription,     #}
{#   pageImage, pageCss, pageScripts               #}
{# ГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђ #}
{# Rule 4: dir attribute is ALWAYS present so the browser never defaults wrong #}
<!DOCTYPE html>
<html lang="{{ lang }}" dir="{{ dir }}">

<head>
  <meta charset="UTF-8">

  {# ГўвЂќв‚¬ГўвЂќв‚¬ Meta Pixel (Facebook) ГўвЂќв‚¬ГўвЂќв‚¬ #}
  <script>
  !function(f,b,e,v,n,t,s)
  {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
  n.callMethod.apply(n,arguments):n.queue.push(arguments)};
  if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
  n.queue=[];t=b.createElement(e);t.async=!0;
  t.src=v;s=b.getElementsByTagName(e)[0];
  s.parentNode.insertBefore(t,s)}(window, document,'script',
  'https://connect.facebook.net/en_US/fbevents.js');
  fbq('init', '3946935715602952');
  fbq('track', 'PageView');
  </script>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <script>document.documentElement.setAttribute('data-theme',localStorage.getItem('theme')||'dark')</script>
  <title>{{ pageTitle or t.meta.title }}</title>
  <meta name="description" content="{{ pageDescription or t.meta.description }}">
  <meta name="keywords" content="{{ t.meta.keywords }}">
  <link rel="icon" type="image/png" href="/images/nabda-new-logo-light.png">

  {# ГўвЂќв‚¬ГўвЂќв‚¬ CSRF Token (read by api.js for all mutating requests) ГўвЂќв‚¬ГўвЂќв‚¬ #}
  {% if csrfToken %}
  <meta name="csrf-token" content="{{ csrfToken }}">
  {% endif %}

  {# ГўвЂќв‚¬ГўвЂќв‚¬ Canonical & hreflang (bilingual SEO) ГўвЂќв‚¬ГўвЂќв‚¬ #}
  <link rel="canonical" href="{{ baseUrl }}{{ currentPath }}">
  <link rel="alternate" hreflang="en" href="{{ baseUrl }}{{ currentPath }}">
  <link rel="alternate" hreflang="ar" href="{{ baseUrl }}{{ currentPath }}">
  <link rel="alternate" hreflang="x-default" href="{{ baseUrl }}{{ currentPath }}">

  {# ГўвЂќв‚¬ГўвЂќв‚¬ OpenGraph (Facebook, LinkedIn, WhatsApp) ГўвЂќв‚¬ГўвЂќв‚¬ #}
  <meta property="og:site_name" content="Nabda Platform">
  <meta property="og:type" content="website">
  <meta property="og:locale" content="{{ 'ar_SA' if isRTL else 'en_US' }}">
  <meta property="og:locale:alternate" content="{{ 'en_US' if isRTL else 'ar_SA' }}">
  <meta property="og:title" content="{{ pageTitle or t.meta.title }}">
  <meta property="og:description" content="{{ pageDescription or t.meta.description }}">
  <meta property="og:url" content="{{ baseUrl }}{{ currentPath }}">
  
  <meta property="og:image" itemprop="image" content="{{ pageImage or (baseUrl + '/images/og-default.jpg') }}">
  <meta property="og:image:secure_url" itemprop="image" content="{{ pageImage or (baseUrl + '/images/og-default.jpg') }}">
  <meta property="og:image:type" content="image/png">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">

  {# ГўвЂќв‚¬ГўвЂќв‚¬ Twitter Card ГўвЂќв‚¬ГўвЂќв‚¬ #}
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ pageTitle or t.meta.title }}">
  <meta name="twitter:description" content="{{ pageDescription or t.meta.description }}">
  <meta name="twitter:image" content="{{ pageImage or (baseUrl + '/images/og-default.jpg') }}">

  {# ГўвЂќв‚¬ГўвЂќв‚¬ JSON-LD Structured Data ГўвЂќв‚¬ГўвЂќв‚¬ #}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "ProfessionalService",
    "name": "Nabda Platform",
    "url": "{{ baseUrl }}",
    "logo": "{{ baseUrl }}/images/nabda-new-logo.png",
    "description": "{{ t.meta.description }}",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Badr City",
      "addressRegion": "Cairo Governorate",
      "addressCountry": "EG"
    },
    "areaServed": ["EG", "SA", "AE"],
    "serviceType": ["Advertising", "Marketing", "Real Estate", "Exhibition Management"],
    "sameAs": []
  }
  </script>

  {# ГўвЂќв‚¬ГўвЂќв‚¬ Fonts: Cairo for RTL, Inter for LTR ГўвЂќв‚¬ГўвЂќв‚¬ #}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  {% if isRTL %}
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700&display=swap">
  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700&display=swap" rel="stylesheet">
  {% else %}
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  {% endif %}

  {# ГўвЂќв‚¬ГўвЂќв‚¬ Icons ГўвЂќв‚¬ГўвЂќв‚¬ #}
  <link rel="preconnect" href="https://cdnjs.cloudflare.com" crossorigin>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

  {# ГўвЂќв‚¬ГўвЂќв‚¬ Core Styles ГўвЂќв‚¬ГўвЂќв‚¬ #}
  <link rel="stylesheet" href="/css/main.css?v=5">

  {# ГўвЂќв‚¬ГўвЂќв‚¬ Page-specific CSS ГўвЂќв‚¬ГўвЂќв‚¬ #}
  {% block pageCss %}{% endblock %}

  {# ГўвЂќв‚¬ГўвЂќв‚¬ RTL Styles (auto-loaded for Arabic) ГўвЂќв‚¬ГўвЂќв‚¬ #}
  {% if isRTL %}
  <link rel="stylesheet" href="/css/rtl.css?v=3">
  {% endif %}



  {# ГўвЂќв‚¬ГўвЂќв‚¬ Extra head content ГўвЂќв‚¬ГўвЂќв‚¬ #}
  {% block headExtra %}{% endblock %}
</head>

<body>
  {# ГўвЂќв‚¬ГўвЂќв‚¬ Meta Pixel noscript fallback ГўвЂќв‚¬ГўвЂќв‚¬ #}
  <noscript><img height="1" width="1" style="display:none"
    src="https://www.facebook.com/tr?id=3946935715602952&ev=PageView&noscript=1"
  /></noscript>


  {# ГўвЂќв‚¬ГўвЂќв‚¬ Page Content ГўвЂќв‚¬ГўвЂќв‚¬ #}
  {% block body %}{% endblock %}

  {# ГўвЂќв‚¬ГўвЂќв‚¬ Toast Container ГўвЂќв‚¬ГўвЂќв‚¬ #}
  <div class="toast-container" id="toastContainer"></div>

  {# ГўвЂќв‚¬ГўвЂќв‚¬ Core Scripts ГўвЂќв‚¬ГўвЂќв‚¬ #}
  <script src="/js/api.js?v=20260409" defer></script>
  <script src="/js/utils.js?v=3" defer></script>
  <script src="/js/i18n-switcher.js?v=4" defer></script>

  {# ГўвЂќв‚¬ГўвЂќв‚¬ Page-specific Scripts ГўвЂќв‚¬ГўвЂќв‚¬ #}
  {% block pageScripts %}{% endblock %}

  {# ГўвЂќв‚¬ГўвЂќв‚¬ AI Chatbot Widget (HOME PAGE ONLY) ГўвЂќв‚¬ГўвЂќв‚¬ #}
  {% if isHomePage %}
  <link rel="stylesheet" href="/css/chatbot.css">

  <button class="chatbot-fab" id="chatbotFab" aria-label="Chat with AI">
    <span class="fab-open"><i class="fas fa-wand-magic-sparkles"></i></span>
    <span class="fab-close"><i class="fas fa-times"></i></span>
  </button>

  <div class="chatbot-window" id="chatbotWindow">
    <div class="chatbot-header">
      <div class="chatbot-header-avatar"><i class="fas fa-wand-magic-sparkles"></i></div>
      <div class="chatbot-header-info">
        <h4>Nabda AI</h4>
        <span id="chatbotOnline">{{ t.chatbot.online | default('Online now') }}</span>
      </div>
    </div>
    <div class="chatbot-messages" id="chatbotMessages"></div>
    <div class="chatbot-input-area">
      <input type="text" class="chatbot-input" id="chatbotInput" placeholder="{{ t.chatbot.placeholder | default('Type your message...') }}" maxlength="300" autocomplete="off">
      <button class="chatbot-send" id="chatbotSend" aria-label="Send"><i class="fas fa-paper-plane"></i></button>
    </div>
  </div>

  <script src="/js/chatbot.js" defer></script>
  {% endif %}
</body>

</html>


