{# ═══════════════════════════════════════════════ #}
{# Admin Command Center V2.0                       #}
{# Uses base layout (own sidebar, no shared navbar) #}
{# ═══════════════════════════════════════════════ #}
{% extends "layouts/base.njk" %}

{% set pageTitle = t.admin.title %}

{% block pageCss %}
  <link rel="stylesheet" href="/css/dashboard.css">
  <script src="https://cdn.jsdelivr.net/npm/apexcharts@3.46.0/dist/apexcharts.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.8.2/jspdf.plugin.autotable.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
  {# FIX (F5): All admin styles moved to dashboard.css — no more inline <style> #}
{% endblock %}

{% block body %}
  <div class="dashboard-layout">

    {# ════════════ SIDEBAR ════════════ #}
    <aside class="sidebar" id="sidebar">
      <div class="sidebar-header">
        <a href="/" class="sidebar-logo">
          <img class="logo-for-dark" src="/images/nabda-logo-transparent.svg" alt="{{ logoAlt }}" style="height:44px;width:auto;object-fit:contain;">
          <img class="logo-for-light" src="/images/nabda-logo-dark.svg" alt="{{ logoAlt }}" style="height:44px;width:auto;object-fit:contain;">
        </a>
        <button type="button" class="sidebar-close" id="sidebarClose" aria-label="Close Sidebar"><i class="fas fa-times" aria-hidden="true"></i></button>
      </div>

      <nav class="sidebar-nav">
        <div class="nav-section">{{ t.admin.commandCenter }}</div>
        <button class="sidebar-link active" data-view="stats">
          <span class="icon"><i class="fas fa-chart-line"></i></span> {{ t.admin.executiveInsights }}
          <span class="kbd-hint">1</span>
        </button>
        <button class="sidebar-link" data-view="orders">
          <span class="icon"><i class="fas fa-shopping-bag"></i></span> {{ t.admin.orders }}
          <span class="kbd-hint">2</span>
        </button>

        <div class="nav-section">{{ t.admin.contentSection }}</div>
        <button class="sidebar-link" data-view="services">
          <span class="icon"><i class="fas fa-concierge-bell"></i></span> {{ t.admin.services }}
          <span class="kbd-hint">3</span>
        </button>
        <button class="sidebar-link" data-view="exhibitions">
          <span class="icon" style="display:flex;align-items:center;justify-content:center;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="premium-icon">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
              <line x1="16" y1="2" x2="16" y2="6"></line>
              <line x1="8" y1="2" x2="8" y2="6"></line>
              <line x1="3" y1="10" x2="21" y2="10"></line>
              <path d="M8 14h.01"></path><path d="M12 14h.01"></path><path d="M16 14h.01"></path>
              <path d="M8 18h.01"></path><path d="M12 18h.01"></path><path d="M16 18h.01"></path>
            </svg>
          </span> 
          {{ t.admin.exhibitions }}
          <span class="kbd-hint">4</span>
        </button>
        <button class="sidebar-link" data-view="jobs">
          <span class="icon"><i class="fas fa-briefcase"></i></span> {{ t.admin.jobsNav }}
          <span class="kbd-hint">5</span>
        </button>
        <button class="sidebar-link" data-view="portfolio">
          <span class="icon"><i class="fas fa-images"></i></span> {{ t.admin.portfolioNav }}
          <span class="kbd-hint">6</span>
        </button>

        <div class="nav-section">{{ t.admin.supportSection }}</div>
        <button class="sidebar-link" data-view="messages">
          <span class="icon"><i class="fas fa-headset"></i></span> {{ t.admin.ticketCenter }}
          <span class="badge-count hidden" id="unreadMsgCount">0</span>
          <span class="kbd-hint">6</span>
        </button>

        <div class="nav-section" data-min-role="admin">{{ t.admin.administration }}</div>
        <button class="sidebar-link" data-view="users" data-min-role="admin">
          <span class="icon"><i class="fas fa-users-cog"></i></span> {{ t.admin.users }}
          <span class="kbd-hint">7</span>
        </button>
        <button class="sidebar-link" data-view="roles" data-min-role="admin">
          <span class="icon"><i class="fas fa-shield-halved"></i></span> {{ t.admin.roles }}
          <span class="kbd-hint">8</span>
        </button>
        <button class="sidebar-link" data-view="logs" data-min-role="admin">
          <span class="icon"><i class="fas fa-file-lines"></i></span> {{ t.admin.loginLogs }}
          <span class="kbd-hint">9</span>
        </button>
      </nav>

      <div class="sidebar-footer">
        <div class="sidebar-user">
          <div class="avatar" id="adminAvatar">A</div>
          <div>
            <div class="name" id="adminName">{{ t.admin.adminDefault }}</div>
            <div class="role" id="adminRole">{{ t.admin.superAdmin }}</div>
          </div>
        </div>
      </div>
    </aside>
    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    {# ════════════ MAIN ════════════ #}
    <div class="main-content">
      <div class="topbar">
        <div class="topbar-left">
          <button type="button" class="sidebar-toggle" id="sidebarToggle" aria-label="Toggle Sidebar"><i class="fas fa-bars" aria-hidden="true"></i></button>
          <div class="topbar-title">
            <h1 id="viewTitle" style="font-size: 1.5rem; margin: 0; color: var(--text-1);">{{ t.admin.executiveInsights }}</h1>
            <span>{{ t.admin.commandCenter }}</span>
          </div>
        </div>
        <div class="topbar-right" style="display:flex;align-items:center;gap:12px;">
          <div class="global-search">
            <i class="fas fa-search search-icon"></i>
            <input type="text" id="globalSearchInput" placeholder="{{ t.admin.searchPlaceholder }}" autocomplete="off">
            <div class="search-results" id="searchResults"></div>
          </div>
          <span class="live-clock" id="liveClock"></span>
          <a href="/api/set-lang?lang={{ langToggle.switchTo }}&redirect=/admin" class="topbar-btn" title="{{ langToggle.text }}" data-tooltip="{{ langToggle.text }}">
            <img src="{{ langToggle.flag }}" alt="{{ langToggle.text }}" style="width:18px;height:auto;border-radius:2px;">
          </a>
          <a href="/dashboard" class="btn btn-ghost btn-sm" data-tooltip="{{ t.admin.switchToClientView | default('Switch to Client View') }}"><i class="fas fa-exchange-alt"></i> {{ t.admin.clientView }}</a>
          <button type="button" class="topbar-btn" title="{{ t.admin.logoutBtn }}" id="logoutBtn" aria-label="{{ t.admin.logoutBtn }}" data-tooltip="{{ t.admin.logoutBtn }}"><i class="fas fa-sign-out-alt" aria-hidden="true"></i></button>
        </div>
      </div>

      {# Breadcrumb #}
      <div class="breadcrumb-strip" id="adminBreadcrumb">
        <a href="/"><i class="fas fa-home"></i></a>
        <span class="separator">/</span>
        <a href="/admin">{{ t.admin.commandCenter }}</a>
        <span class="separator">/</span>
        <span class="current" id="adminBreadcrumbCurrent">{{ t.admin.executiveInsights }}</span>
      </div>

      <div class="content-area">

        {# ── EXECUTIVE INSIGHTS ── #}
        <div class="view-section active" id="view-stats">
          <div class="exec-grid" id="execGrid">
            <div class="exec-card">
              <div class="exec-icon revenue"><i class="fas fa-dollar-sign"></i></div>
              <div class="exec-label">{{ t.admin.totalRevenue }}</div>
              <div class="exec-value" id="execRevenue"><div class="skeleton skeleton-value"></div></div>
              <div class="exec-bar"><div class="exec-bar-fill green" id="execRevenueBar" style="width:0%"></div></div>
            </div>
            <div class="exec-card">
              <div class="exec-icon conversion"><i class="fas fa-chart-pie"></i></div>
              <div class="exec-label">{{ t.admin.conversionRate }}</div>
              <div class="exec-value" id="execConversion"><div class="skeleton skeleton-value"></div></div>
              <div class="exec-bar"><div class="exec-bar-fill blue" id="execConversionBar" style="width:0%"></div></div>
            </div>
            <div class="exec-card">
              <div class="exec-icon content"><i class="fas fa-layer-group"></i></div>
              <div class="exec-label">{{ t.admin.activeContent }}</div>
              <div class="exec-value" id="execContent"><div class="skeleton skeleton-value"></div></div>
              <div class="exec-bar"><div class="exec-bar-fill purple" id="execContentBar" style="width:0%"></div></div>
            </div>
            <div class="exec-card">
              <div class="exec-icon support"><i class="fas fa-envelope-open-text"></i></div>
              <div class="exec-label">{{ t.admin.supportLoad }}</div>
              <div class="exec-value" id="execSupport"><div class="skeleton skeleton-value"></div></div>
              <div class="exec-bar"><div class="exec-bar-fill amber" id="execSupportBar" style="width:0%"></div></div>
            </div>
          </div>

          <div class="stats-grid" id="adminStatsGrid">
            <div class="stat-card">
              <div class="stat-header"><div class="stat-icon purple"><i class="fas fa-users"></i></div><div class="stat-label">{{ t.admin.totalUsers }}</div></div>
              <div class="stat-value" id="aStatUsers"><div class="skeleton skeleton-value"></div></div>
            </div>
            <div class="stat-card">
              <div class="stat-header"><div class="stat-icon blue"><i class="fas fa-shopping-bag"></i></div><div class="stat-label">{{ t.admin.totalOrders }}</div></div>
              <div class="stat-value" id="aStatOrders"><div class="skeleton skeleton-value"></div></div>
            </div>
            <div class="stat-card">
              <div class="stat-header"><div class="stat-icon orange"><i class="fas fa-clock"></i></div><div class="stat-label">{{ t.admin.pendingLabel }}</div></div>
              <div class="stat-value" id="aStatPending"><div class="skeleton skeleton-value"></div></div>
            </div>
            <div class="stat-card">
              <div class="stat-header"><div class="stat-icon cyan"><i class="fas fa-concierge-bell"></i></div><div class="stat-label">{{ t.admin.services }}</div></div>
              <div class="stat-value" id="aStatServices"><div class="skeleton skeleton-value"></div></div>
            </div>
            <div class="stat-card">
              <div class="stat-header"><div class="stat-icon gold"><i class="fas fa-briefcase"></i></div><div class="stat-label">{{ t.admin.jobsNav }}</div></div>
              <div class="stat-value" id="aStatJobs"><div class="skeleton skeleton-value"></div></div>
            </div>
            <div class="stat-card">
              <div class="stat-header"><div class="stat-icon green"><i class="fas fa-calendar-alt"></i></div><div class="stat-label">{{ t.admin.exhibitions }}</div></div>
              <div class="stat-value" id="aStatExhibitions"><div class="skeleton skeleton-value"></div></div>
            </div>
            <div class="stat-card">
              <div class="stat-header"><div class="stat-icon cyan"><i class="fas fa-images"></i></div><div class="stat-label">{{ t.admin.portfolioNav }}</div></div>
              <div class="stat-value" id="aStatPortfolio"><div class="skeleton skeleton-value"></div></div>
            </div>
          </div>

          <div class="charts-section">
            <div class="chart-card">
              <div class="chart-card-header"><div><h3><i class="fas fa-chart-area" style="color:#d4af37;margin-inline-end:8px"></i> {{ t.admin.ordersPerformance }}</h3><div class="chart-subtitle">{{ t.admin.revenueBreakdown }}</div></div></div>
              <div id="revenueChart"></div>
            </div>
            <div class="chart-card">
              <div class="chart-card-header"><div><h3><i class="fas fa-chart-pie" style="color:#10b981;margin-inline-end:8px"></i> {{ t.admin.contentMix }}</h3><div class="chart-subtitle">{{ t.admin.contentMixSubtitle }}</div></div></div>
              <div id="distributionChart"></div>
            </div>
          </div>
          <div id="adminStatsChart" style="display:none"></div>

          <div class="dashboard-card full-width">
            <div class="card-header"><h3><i class="fas fa-history"></i> {{ t.admin.recentOrders }}</h3></div>
            <div class="table-container">
              <table class="data-table">
                <thead><tr><th>{{ t.admin.thInvoice }}</th><th>{{ t.admin.thClient }}</th><th>{{ t.admin.thService }}</th><th>{{ t.admin.thAmount }}</th><th>{{ t.admin.thStatus }}</th><th>{{ t.admin.thDate }}</th></tr></thead>
                <tbody id="adminRecentOrders"><tr><td colspan="6"><div class="skeleton skeleton-row"></div></td></tr><tr><td colspan="6"><div class="skeleton skeleton-row"></div></td></tr><tr><td colspan="6"><div class="skeleton skeleton-row"></div></td></tr></tbody>
              </table>
            </div>
          </div>
        </div>

        {# ── ORDERS ── #}
        <div class="view-section" id="view-orders">
          <div class="filters-bar">
            <select class="form-select" id="adminOrderStatus" onchange="loadAdminOrders()">
              <option value="">{{ t.admin.allFilter }}</option>
              <option value="pending">{{ t.admin.pendingLabel }}</option>
              <option value="in_progress">{{ t.admin.inProgressLabel }}</option>
              <option value="completed">{{ t.admin.completedLabel }}</option>
              <option value="cancelled">{{ t.admin.cancelledLabel }}</option>
            </select>
            <button class="btn btn-outline btn-sm" onclick="exportTableCSV('adminOrdersTable', 'orders')"><i class="fas fa-file-csv"></i> {{ t.admin.exportCsv }}</button>
            <button class="btn btn-outline btn-sm" onclick="exportTablePDF('adminOrdersTable', 'orders')"><i class="fas fa-file-pdf" style="color:#e74c3c"></i> {{ t.admin.exportPdf | default('PDF') }}</button>
            <button class="btn btn-outline btn-sm" onclick="exportTableExcel('adminOrdersTable', 'orders')"><i class="fas fa-file-excel" style="color:#27ae60"></i> {{ t.admin.exportExcel | default('Excel') }}</button>
            <button class="btn btn-outline btn-sm" onclick="exportTableWord('adminOrdersTable', 'orders')"><i class="fas fa-file-word" style="color:#2980b9"></i> {{ t.admin.exportWord | default('Word') }}</button>
          </div>
          <div class="table-container"><table class="data-table"><thead><tr><th>{{ t.admin.thInvoice }}</th><th>{{ t.admin.thClient }}</th><th>{{ t.admin.thService }}</th><th>{{ t.admin.thAmount }}</th><th>{{ t.admin.thStatus }}</th><th>{{ t.admin.thDate }}</th><th>{{ t.admin.thActions }}</th></tr></thead><tbody id="adminOrdersTable"></tbody></table></div>
          <div class="pagination" id="adminOrdersPagination"></div>
        </div>

        {# ── SERVICES ── #}
        <div class="view-section" id="view-services">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;flex-wrap:wrap;gap:8px">
            <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap"><span style="font-size:0.85rem;color:var(--text-2)" id="svcBulkInfo"></span></div>
            <button class="btn btn-primary btn-sm" onclick="openServiceModal()"><i class="fas fa-plus"></i> {{ t.admin.addService }}</button>
          </div>
          <div class="table-container"><table class="data-table"><thead><tr><th style="width:30px"><input type="checkbox" id="svcSelectAll" onchange="toggleAllCheckboxes('svc')"></th><th>{{ t.admin.thTitle }}</th><th>{{ t.admin.thPrice }}</th><th>{{ t.admin.thFeatured }}</th><th>{{ t.admin.thActive }}</th><th>{{ t.admin.thCreated }}</th><th>{{ t.admin.thActions }}</th></tr></thead><tbody id="adminServicesTable"></tbody></table></div>
        </div>

        {# ── EXHIBITIONS ── #}
        <div class="view-section" id="view-exhibitions">
        <div style="display:flex;justify-content:flex-end;margin-bottom:20px;gap:8px">
            <button class="btn btn-primary btn-sm" onclick="openExhibitionModal()">
              <i class="fas fa-plus"></i> {{ t.admin.addExhibition }}
            </button>
          </div>
          <div class="exhibition-admin-grid" id="adminExhibitionsGrid">
            <div style="grid-column:1/-1;padding:40px;text-align:center;color:var(--text-3)">
              <i class="fas fa-spin fa-spinner" style="font-size:1.5rem"></i>
            </div>
          </div>
        </div>

        {# ── PROPERTIES ── #}
        <div class="view-section" id="view-properties">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;flex-wrap:wrap;gap:8px">
            <span style="font-size:0.85rem;color:var(--text-2)" id="propBulkInfo"></span>
            <div style="display:flex;gap:8px">
              <button class="btn btn-outline btn-sm" onclick="exportTableCSV('adminPropertiesTable', 'properties')"><i class="fas fa-download"></i> {{ t.admin.exportCsv }}</button>
              <button class="btn btn-primary btn-sm" onclick="openPropertyModal()"><i class="fas fa-plus"></i> {{ t.admin.addProperty }}</button>
            </div>
          </div>
          <div class="table-container"><table class="data-table"><thead><tr><th style="width:30px"><input type="checkbox" id="propSelectAll" onchange="toggleAllCheckboxes('prop')"></th><th>{{ t.admin.thTitle }}</th><th>{{ t.admin.thLocation }}</th><th>{{ t.admin.thPrice }}</th><th>{{ t.admin.thType }}</th><th>{{ t.admin.thFeatured }}</th><th>{{ t.admin.thActive }}</th><th>{{ t.admin.thActions }}</th></tr></thead><tbody id="adminPropertiesTable"></tbody></table></div>
        </div>

        {# ── JOBS ── #}
        <div class="view-section" id="view-jobs">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;flex-wrap:wrap;gap:8px">
            <span style="font-size:0.85rem;color:var(--text-2)">{{ t.admin.jobsNav }}</span>
            <button class="btn btn-primary btn-sm" onclick="openJobModal()"><i class="fas fa-plus"></i> {{ t.admin.addJob }}</button>
          </div>
          <div class="table-container">
            <table class="data-table">
              <thead><tr>
                <th>{{ t.admin.thTitle }}</th>
                <th>{{ t.admin.jobCompany }}</th>
                <th>{{ t.admin.jobLocation }}</th>
                <th>{{ t.admin.jobType }}</th>
                <th>{{ t.admin.thActive }}</th>
                <th>{{ t.admin.thActions }}</th>
              </tr></thead>
              <tbody id="jobsTableBody"></tbody>
            </table>
          </div>
        </div>

        {# ── PORTFOLIO ── #}
        <div class="view-section" id="view-portfolio">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;flex-wrap:wrap;gap:8px">
            <span style="font-size:0.85rem;color:var(--text-2)">{{ t.admin.portfolioNav }}</span>
            <button class="btn btn-primary btn-sm" onclick="openPortfolioModal()"><i class="fas fa-plus"></i> {{ t.admin.addPortfolio }}</button>
          </div>
          <div class="table-container">
            <table class="data-table">
              <thead><tr>
                <th style="width:60px">{{ t.admin.thImage }}</th>
                <th>{{ t.admin.thTitle }}</th>
                <th>{{ t.admin.portfolioCategory }}</th>
                <th>{{ t.admin.thActive }}</th>
                <th>{{ t.admin.thActions }}</th>
              </tr></thead>
              <tbody id="portfolioTableBody"></tbody>
            </table>
          </div>
        </div>

        {# ── TICKET CENTER ── #}
        <div class="view-section" id="view-messages">
          <div class="filters-bar">
            <select class="form-select" id="msgStatusFilter" onchange="loadAdminMessages()">
              <option value="">{{ t.admin.allMessages }}</option>
              <option value="new">{{ t.admin.newFilter }}</option>
              <option value="replied">{{ t.admin.repliedFilter }}</option>
            </select>
          </div>
          <div id="adminMessagesContainer"><div class="empty-state"><div class="icon"><i class="fas fa-inbox"></i></div><h3>{{ t.admin.loading }}</h3></div></div>
          <div class="pagination" id="adminMsgPagination"></div>
        </div>

        {# ── USERS ── #}
        <div class="view-section" id="view-users">
          <div class="filters-bar">
            <input class="form-input search-input" type="text" id="userSearch" placeholder="{{ t.admin.userSearchPlaceholder }}" onkeyup="loadAdminUsers()">
            <button class="btn btn-outline btn-sm" onclick="exportTableCSV('adminUsersTable', 'users')"><i class="fas fa-download"></i> {{ t.admin.exportCsv }}</button>
          </div>
          <div class="table-container"><table class="data-table"><thead><tr><th>{{ t.admin.thUser }}</th><th>{{ t.admin.thEmail }}</th><th>{{ t.admin.thPhone }}</th><th>{{ t.admin.thRole }}</th><th>{{ t.admin.thStatus }}</th><th>{{ t.admin.thVerified }}</th><th>{{ t.admin.thLastLogin }}</th><th>{{ t.admin.thActions }}</th></tr></thead><tbody id="adminUsersTable"></tbody></table></div>
          <div class="pagination" id="adminUsersPagination"></div>
        </div>

        {# ── ROLES ── #}
        <div class="view-section" id="view-roles">
          <div class="table-container"><table class="data-table"><thead><tr><th>{{ t.admin.thRole }}</th><th>{{ t.admin.thDescription }}</th><th>{{ t.admin.thPermissions }}</th></tr></thead><tbody id="adminRolesTable"></tbody></table></div>
        </div>

        {# ── LOGS ── #}
        <div class="view-section" id="view-logs">
          <div class="filters-bar" style="justify-content: flex-end;">
            <button class="btn btn-danger btn-sm" id="clearLogsBtn" onclick="clearAdminLogs()" style="display:none;"><i class="fas fa-trash-alt"></i> {{ t.admin.clearAllLogs }}</button>
          </div>
          <div class="table-container"><table class="data-table"><thead><tr><th>{{ t.admin.thUser }}</th><th>{{ t.admin.thEmail }}</th><th>{{ t.admin.thIP }}</th><th>{{ t.admin.thBrowser }}</th><th>{{ t.admin.thStatus }}</th><th>{{ t.admin.thTime }}</th></tr></thead><tbody id="adminLogsTable"></tbody></table></div>
          <div class="pagination" id="adminLogsPagination"></div>
        </div>

      </div>
    </div>
  </div>

  {# ══════ CONFIRMATION DIALOG ══════ #}
  <div class="modal-overlay" id="confirmModal">
    <div class="confirm-dialog">
      <div class="confirm-icon warning" id="confirmIcon"><i class="fas fa-exclamation-triangle"></i></div>
      <h3 id="confirmTitle">{{ t.admin.confirmTitle }}</h3>
      <p id="confirmMessage">{{ t.admin.confirmMessage }}</p>
      <div class="confirm-actions">
        <button class="btn btn-outline" onclick="closeConfirmModal()">{{ t.admin.cancelBtn }}</button>
        <button class="btn btn-danger" id="confirmActionBtn">{{ t.admin.confirmBtn }}</button>
      </div>
    </div>
  </div>

  {# ══════ COMMAND PALETTE ══════ #}
  <div class="command-palette-overlay" id="commandPalette">
    <div class="command-palette">
      <input type="text" class="command-palette-input" id="cmdInput" placeholder="{{ t.admin.cmdPlaceholder }}" autocomplete="off">
      <div class="command-palette-results" id="cmdResults"></div>
      <div class="command-palette-footer">
        <span><kbd>↑↓</kbd> {{ t.admin.cmdNavigate }}</span>
        <span><kbd>↵</kbd> {{ t.admin.cmdSelect }}</span>
        <span><kbd>Esc</kbd> {{ t.admin.cmdClose }}</span>
      </div>
    </div>
  </div>

  {# ══════ SERVICE MODAL ══════ #}
  <div class="modal-overlay" id="serviceModal">
    <div class="modal-content">
      <div class="modal-header">
        <h3 id="serviceModalTitle">{{ t.admin.addService }}</h3>
