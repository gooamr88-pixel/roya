{# ═══════════════════════════════════════════════ #}
{# Footer Partial                                   #}
{# ═══════════════════════════════════════════════ #}
<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="/" class="footer-logo-group">
          <img class="logo-for-dark" src="/images/nabda-logo-transparent.svg" alt="{{ logoAlt }}" loading="lazy" decoding="async" style="height:40px;width:auto;object-fit:contain;">
          <img class="logo-for-light" src="/images/nabda-logo-dark.svg" alt="{{ logoAlt }}" loading="lazy" decoding="async" style="height:40px;width:auto;object-fit:contain;">
          {% if brandNameIsImage %}
            <img src="{{ brandNameSrc }}" alt="{{ logoAlt }}" class="brand-name-img" style="height:28px;width:auto;">
          {% else %}
            <span class="brand-name">{{ logoAlt }}</span>
          {% endif %}
        </a>
        <p data-i18n="footer.brand_desc">{{ t.footer.brand_desc }}</p>
        <div style="margin-top: 16px; font-size: 0.9rem; color: var(--text-muted);">
          <p><i class="fas fa-phone" style="margin-{{ 'left' if isRTL else 'right' }}: 8px;"></i> <span dir="ltr" style="display: inline-block;">+20 1025474922</span></p>
          <p><i class="fab fa-whatsapp" style="margin-{{ 'left' if isRTL else 'right' }}: 8px;"></i> <span dir="ltr" style="display: inline-block;">+966 548 171 795</span></p>
        </div>
      </div>

      <div>
        <h4 data-i18n="footer.quickLinks">{{ t.footer.quickLinks }}</h4>
        <ul class="footer-links">
          <li><a href="#about" data-i18n="nav.about">{{ t.nav.about }}</a></li>
          <li><a href="#services" data-i18n="nav.services">{{ t.nav.services }}</a></li>
          <li><a href="#properties" data-i18n="nav.properties">{{ t.nav.properties }}</a></li>
          <li><a href="#contact" data-i18n="nav.contact">{{ t.nav.contact }}</a></li>
          <li><a href="#portfolio" data-i18n="nav.portfolio">{{ t.nav.portfolio }}</a></li>
        </ul>
      </div>

      <div>
        <h4 data-i18n="footer.servicesTitle">{{ t.footer.servicesTitle }}</h4>
        <ul class="footer-links">
          <li><a href="#services" data-i18n="about.advertising">{{ t.about.advertising }}</a></li>
          <li><a href="#services" data-i18n="about.marketing">{{ t.about.marketing }}</a></li>
          <li><a href="#services" data-i18n="about.realEstate">{{ t.about.realEstate }}</a></li>
          <li><a href="#services" data-i18n="about.exhibitions">{{ t.about.exhibitions }}</a></li>
        </ul>
      </div>

      <div>
        <h4 data-i18n="footer.account">{{ t.footer.account }}</h4>
        <ul class="footer-links">
          <li><a href="/login" data-i18n="footer.signIn">{{ t.footer.signIn }}</a></li>
          <li><a href="/register" data-i18n="footer.register">{{ t.footer.register }}</a></li>
          <li><a href="/dashboard" data-i18n="footer.dashboard">{{ t.footer.dashboard }}</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <span class="footer-copyright-text" data-i18n="footer.copyright">{{ t.footer.copyright }}</span>
      <div class="footer-social">
        <a href="#" aria-label="TikTok"><i class="fab fa-tiktok"></i></a>
        <a href="#" aria-label="Snapchat"><i class="fab fa-snapchat"></i></a>
        <a href="#" aria-label="Instagram"><i class="fab fa-instagram"></i></a>
        <a href="#" aria-label="Facebook"><i class="fab fa-facebook-f"></i></a>
      </div>
      <div class="footer-credit">
        <span data-i18n="footer.createdBy">{{ t.footer.createdBy | default('Designed & Developed by') }}</span>
        <a href="https://wa.me/2001108607033" target="_blank" rel="noopener" class="footer-credit-link">Yousef Amr</a>
      </div>
    </div>
  </div>
</footer>
