# ═══════════════════════════════════════════════
# ROYA PLATFORM — Environment Config
# ═══════════════════════════════════════════════

# ── Server ──
PORT=3000
NODE_ENV=development

# ── Database (PostgreSQL) ──
DB_HOST=localhost
DB_PORT=5432
DB_NAME=roya_platform
DB_USER=postgres
DB_PASSWORD=your_db_password

# ── JWT ──
JWT_ACCESS_SECRET=your_access_secret_change_this_in_production
JWT_REFRESH_SECRET=your_refresh_secret_change_this_in_production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── Email (SMTP / Nodemailer) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM="Roya Platform <noreply@roya.com>"

# ── Cloudinary ──
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── WhatsApp API (Twilio example) ──
WHATSAPP_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Security ──
CSRF_SECRET=your_csrf_secret_change_this
COOKIE_DOMAIN=localhost
ALLOWED_ORIGINS=http://localhost:3000

# ── Super Admin Seed ──
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_EMAIL=admin@roya.com
SUPER_ADMIN_PHONE=+966500000000
SUPER_ADMIN_PASSWORD=Admin@123456
