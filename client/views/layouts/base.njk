{# ═══════════════════════════════════════════════ #}
{# Base Layout — Shared by ALL pages              #}
{# Variables injected by i18n middleware:          #}
{#   lang, dir, isRTL, t, logoSrc, logoAlt,       #}
{#   langToggle, baseUrl                           #}
{# Each page sets: pageTitle, pageDescription,     #}
{#   pageImage, pageCss, pageScripts               #}
{# ═══════════════════════════════════════════════ #}
{# Rule 4: dir attribute is ALWAYS present so the browser never defaults wrong #}
<!DOCTYPE html>
<html lang="{{ lang }}" dir="{{ dir }}">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <script>document.documentElement.setAttribute('data-theme',localStorage.getItem('theme')||'dark')</script>
  <title>{{ pageTitle or t.meta.title }}</title>
  <meta name="description" content="{{ pageDescription or t.meta.description }}">
  <meta name="keywords" content="{{ t.meta.keywords }}">
  <link rel="icon" type="image/svg+xml" href="/images/nabda-logo-transparent.svg">

  {# ── CSRF Token (read by api.js for all mutating requests) ── #}
  {% if csrfToken %}
  <meta name="csrf-token" content="{{ csrfToken }}">
  {% endif %}

  {# ── Canonical & hreflang (bilingual SEO) ── #}
  <link rel="canonical" href="{{ baseUrl }}{{ currentPath }}">
  <link rel="alternate" hreflang="en" href="{{ baseUrl }}{{ currentPath }}">
  <link rel="alternate" hreflang="ar" href="{{ baseUrl }}{{ currentPath }}">
  <link rel="alternate" hreflang="x-default" href="{{ baseUrl }}{{ currentPath }}">

  {# ── OpenGraph (Facebook, LinkedIn, WhatsApp) ── #}
  <meta property="og:site_name" content="Nabda Platform">
  <meta property="og:type" content="website">
  <meta property="og:locale" content="{{ 'ar_SA' if isRTL else 'en_US' }}">
  <meta property="og:locale:alternate" content="{{ 'en_US' if isRTL else 'ar_SA' }}">
  <meta property="og:title" content="{{ pageTitle or t.meta.title }}">
  <meta property="og:description" content="{{ pageDescription or t.meta.description }}">
  <meta property="og:url" content="{{ baseUrl }}{{ currentPath }}">
  
  <meta property="og:image" itemprop="image" content="{{ pageImage or (baseUrl + '/images/og-default.jpg') }}">
  <meta property="og:image:secure_url" itemprop="image" content="{{ pageImage or (baseUrl + '/images/og-default.jpg') }}">
  <meta property="og:image:type" content="image/png">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">

  {# ── Twitter Card ── #}
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ pageTitle or t.meta.title }}">
  <meta name="twitter:description" content="{{ pageDescription or t.meta.description }}">
  <meta name="twitter:image" content="{{ pageImage or (baseUrl + '/images/og-default.jpg') }}">

  {# ── JSON-LD Structured Data ── #}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "ProfessionalService",
    "name": "Nabda Platform",
    "url": "{{ baseUrl }}",
    "logo": "{{ baseUrl }}/images/nabda-logo-transparent.svg",
    "description": "{{ t.meta.description }}",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Badr City",
      "addressRegion": "Cairo Governorate",
      "addressCountry": "EG"
    },
    "areaServed": ["EG", "SA", "AE"],
    "serviceType": ["Advertising", "Marketing", "Real Estate", "Exhibition Management"],
    "sameAs": []
  }
  </script>

  {# ── Fonts: Cairo for RTL, Inter for LTR ── #}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  {% if isRTL %}
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700&display=swap">
  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700&display=swap" rel="stylesheet">
  {% else %}
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  {% endif %}

  {# ── Icons ── #}
  <link rel="preconnect" href="https://cdnjs.cloudflare.com" crossorigin>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

  {# ── Core Styles ── #}
  <link rel="stylesheet" href="/css/main.css?v=5">

  {# ── Page-specific CSS ── #}
  {% block pageCss %}{% endblock %}

  {# ── RTL Styles (auto-loaded for Arabic) ── #}
  {% if isRTL %}
  <link rel="stylesheet" href="/css/rtl.css?v=3">
  {% endif %}

  {# ── Facebook Domain Verification ── #}
  <meta name="facebook-domain-verification" content="g1ptepke3cxf74eljssgqz2gkhlk5b" />

  {# ── Facebook Meta Pixel ── #}
  <script>
    !function(f,b,e,v,n,t,s)
    {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
    n.callMethod.apply(n,arguments):n.queue.push(arguments)};
    if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
    n.queue=[];t=b.createElement(e);t.async=!0;
    t.src=v;s=b.getElementsByTagName(e)[0];
    s.parentNode.insertBefore(t,s)}(window, document,'script',
    'https://connect.facebook.net/en_US/fbevents.js');
    fbq('init', '1295164489221044');
    fbq('track', 'PageView');
  </script>

  {# ── Snap Pixel ── #}
  <script type='text/javascript'>
    (function(e,t,n){if(e.snaptr)return;var a=e.snaptr=function()
    {a.handleRequest?a.handleRequest.apply(a,arguments):a.queue.push(arguments)};
    a.queue=[];var s='script';r=t.createElement(s);r.async=!0;
    r.src=n;var u=t.getElementsByTagName(s)[0];
    u.parentNode.insertBefore(r,u);})(window,document,
    'https://sc-static.net/scevent.min.js');

    snaptr('init', '0ee2afbf-3897-4091-a52a-79a507bc5be9', {});
    snaptr('track', 'PAGE_VIEW');
  </script>

  {# ── TikTok Pixel ── #}
  <script>
    !function (w, d, t) {
      w.TiktokAnalyticsObject=t;var ttq=w[t]=w[t]||[];ttq.methods=["page","track","identify","instances","debug","on","off","once","ready","alias","group","enableCookie","disableCookie","holdConsent","revokeConsent","grantConsent"],ttq.setAndDefer=function(t,e){t[e]=function(){t.push([e].concat(Array.prototype.slice.call(arguments,0)))}};for(var i=0;i<ttq.methods.length;i++)ttq.setAndDefer(ttq,ttq.methods[i]);ttq.instance=function(t){for(
      var e=ttq._i[t]||[],n=0;n<ttq.methods.length;n++)ttq.setAndDefer(e,ttq.methods[n]);return e},ttq.load=function(e,n){var r="https://analytics.tiktok.com/i18n/pixel/events.js",o=n&&n.partner;ttq._i=ttq._i||{},ttq._i[e]=[],ttq._i[e]._u=r,ttq._t=ttq._t||{},ttq._t[e]=+new Date,ttq._o=ttq._o||{},ttq._o[e]=n||{};n=document.createElement("script")
      ;n.type="text/javascript",n.async=!0,n.src=r+"?sdkid="+e+"&lib="+t;e=document.getElementsByTagName("script")[0];e.parentNode.insertBefore(n,e)};

      ttq.load('D77RH5BC77U41AUTKLO0');
      ttq.page();
    }(window, document, 'ttq');
  </script>

  {# ── Extra head content ── #}
  {% block headExtra %}{% endblock %}
</head>

<body>
  {# ── Meta Pixel noscript fallback ── #}
  <noscript><img height="1" width="1" style="display:none"
    src="https://www.facebook.com/tr?id=1295164489221044&ev=PageView&noscript=1"
  /></noscript>

  {# ── Page Content ── #}
  {% block body %}{% endblock %}

  {# ── Toast Container ── #}
  <div class="toast-container" id="toastContainer"></div>

  {# ── Core Scripts ── #}
  <script src="/js/api.js?v=3" defer></script>
  <script src="/js/utils.js?v=3" defer></script>
  <script src="/js/i18n-switcher.js?v=4" defer></script>

  {# ── Page-specific Scripts ── #}
  {% block pageScripts %}{% endblock %}

  {# ── AI Chatbot Widget (HOME PAGE ONLY) ── #}
  {% if isHomePage %}
  <link rel="stylesheet" href="/css/chatbot.css">

  <button class="chatbot-fab" id="chatbotFab" aria-label="Chat with AI">
    <span class="fab-open"><i class="fas fa-wand-magic-sparkles"></i></span>
    <span class="fab-close"><i class="fas fa-times"></i></span>
  </button>

  <div class="chatbot-window" id="chatbotWindow">
    <div class="chatbot-header">
      <div class="chatbot-header-avatar"><i class="fas fa-wand-magic-sparkles"></i></div>
      <div class="chatbot-header-info">
        <h4>Nabda AI</h4>
        <span id="chatbotOnline">{{ t.chatbot.online | default('Online now') }}</span>
      </div>
    </div>
    <div class="chatbot-messages" id="chatbotMessages"></div>
    <div class="chatbot-input-area">
      <input type="text" class="chatbot-input" id="chatbotInput" placeholder="{{ t.chatbot.placeholder | default('Type your message...') }}" maxlength="300" autocomplete="off">
      <button class="chatbot-send" id="chatbotSend" aria-label="Send"><i class="fas fa-paper-plane"></i></button>
    </div>
  </div>

  <script src="/js/chatbot.js" defer></script>
  {% endif %}
</body>

</html>
