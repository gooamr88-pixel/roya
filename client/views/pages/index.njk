{# ═══════════════════════════════════════════════ #}
{# Home Page (index)                                #}
{# ═══════════════════════════════════════════════ #}
{% extends "layouts/landing.njk" %}

{% block pageCss %}
  <link rel="stylesheet" href="/css/landing.css?v=7">
{% endblock %}

{% block content %}
    <div class="landing-views-container">
      {# ════════════ HERO (HOME) ════════════ #}
      <section class="landing-view active" id="home">
        <div class="hero-wrapper">
    <div class="hero-slideshow">
      <div class="hero-slide active">
        <img src="https://images.unsplash.com/photo-1497366216548-37526070297c?auto=format&fit=crop&w=800&q=60"
          alt="Corporate Office" width="800" height="450" fetchpriority="high" loading="eager" decoding="sync">
      </div>
      <div class="hero-slide">
        <img src="https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?auto=format&fit=crop&w=800&q=60"
          alt="Modern Architecture" width="800" height="450" loading="lazy" decoding="async">
      </div>
      <div class="hero-slide">
        <img src="https://images.unsplash.com/photo-1600880292203-757bb62b4baf?auto=format&fit=crop&w=800&q=60"
          alt="Business Meeting" width="800" height="450" loading="lazy" decoding="async">
      </div>
      <div class="hero-slide">
        <img src="https://images.unsplash.com/photo-1540575467063-178a50c2df87?auto=format&fit=crop&w=800&q=60"
          alt="Conference Hall" width="800" height="450" loading="lazy" decoding="async">
      </div>
    </div>
    <div class="container">
      <div class="hero-content">


        <h1><span data-i18n="hero.title_before">{{ t.hero.title_before | safe }}</span> <span class="text-gradient" data-i18n="hero.title_highlight">{{ t.hero.title_highlight | safe }}</span> <span data-i18n="hero.title_after">{{ t.hero.title_after | safe }}</span></h1>

        <p style="margin-top: 1.5rem; margin-bottom: 2rem; color: rgba(255, 255, 255, 0.9);" data-i18n="hero.subtitle">{{ t.hero.subtitle }}</p>

        <div class="hero-buttons">
          <a href="#services" class="btn btn-primary btn-lg">
            <i class="fas fa-rocket"></i> <span data-i18n="hero.cta_services">{{ t.hero.cta_services }}</span>
          </a>
          <a href="#contact" class="btn btn-outline btn-lg">
            <i class="fas fa-phone"></i> <span data-i18n="hero.cta_contact">{{ t.hero.cta_contact }}</span>
          </a>
        </div>

        <div class="hero-stats">
          <div class="hero-stat">
            <div class="number" data-count="500">0</div>
            <div class="label" style="color: rgba(255, 255, 255, 0.8);" data-i18n="hero.stat_projects">{{ t.hero.stat_projects }}</div>
          </div>
          <div class="hero-stat">
            <div class="number" data-count="120">0</div>
            <div class="label" style="color: rgba(255, 255, 255, 0.8);" data-i18n="hero.stat_clients">{{ t.hero.stat_clients }}</div>
          </div>
          <div class="hero-stat">
            <div class="number" data-count="15">0</div>
            <div class="label" style="color: rgba(255, 255, 255, 0.8);" data-i18n="hero.stat_years">{{ t.hero.stat_years }}</div>
          </div>
          <div class="hero-stat">
            <div class="number" data-count="25">0</div>
            <div class="label" style="color: rgba(255, 255, 255, 0.8);" data-i18n="hero.stat_team">{{ t.hero.stat_team }}</div>
          </div>
        </div>
      </div>
    </div>
        </div>

       
  </section>

      {# ════════════ ABOUT ════════════ #}
      <section class="landing-view" id="about">
    <div class="container">
      <div class="about-grid">
        <div class="about-visual fade-in-left">
          <div class="about-image-frame">
            <div class="inner">
              <img src="https://images.unsplash.com/photo-1497366216548-37526070297c?auto=format&fit=crop&w=800&q=60"
                alt="{{ t.about.officeAlt }}" width="800" height="600" loading="lazy" decoding="async" style="width: 100%; height: 100%; object-fit: cover; opacity: 0.9;">
            </div>
          </div>
        </div>

        <div class="fade-in-right">
          <span class="section-label" data-i18n="about.label">{{ t.about.label }}</span>
          <h2 class="section-title"><span data-i18n="about.title_before">{{ t.about.title_before | safe }}</span> <span class="text-gradient" data-i18n="about.title_highlight">{{ t.about.title_highlight | safe }}</span></h2>
          <p class="section-desc text-gray-800 dark:text-gray-300" data-i18n="about.desc">{{ t.about.desc }}</p>

          <div class="about-features">
            <div class="about-feature">
              <div class="icon"><i class="fas fa-bullhorn"></i></div>
              <span data-i18n="about.advertising">{{ t.about.advertising }}</span>
            </div>
            <div class="about-feature">
              <div class="icon"><i class="fas fa-chart-line"></i></div>
              <span data-i18n="about.marketing">{{ t.about.marketing }}</span>
            </div>
            <div class="about-feature">
              <div class="icon"><i class="fas fa-building"></i></div>
              <span data-i18n="about.realEstate">{{ t.about.realEstate }}</span>
            </div>
            <div class="about-feature">
              <div class="icon" style="display:flex;align-items:center;justify-content:center;">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                  <line x1="16" y1="2" x2="16" y2="6"></line>
                  <line x1="8" y1="2" x2="8" y2="6"></line>
                  <line x1="3" y1="10" x2="21" y2="10"></line>
                  <path d="M8 14h.01"></path><path d="M12 14h.01"></path><path d="M16 14h.01"></path>
                  <path d="M8 18h.01"></path><path d="M12 18h.01"></path><path d="M16 18h.01"></path>
                </svg>
              </div>
              <span data-i18n="about.exhibitions">{{ t.about.exhibitions }}</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

      {# ════════════ SERVICES ════════════ #}
      <section class="landing-view" id="services">
    <div class="container">
      <div class="text-center fade-in">
        <span class="section-label" data-i18n="services.label">{{ t.services.label }}</span>
        <h2 class="section-title"><span data-i18n="services.title_before">{{ t.services.title_before | safe }}</span> <span class="text-gradient" data-i18n="services.title_highlight">{{ t.services.title_highlight | safe }}</span></h2>
        <p class="section-desc text-gray-800 dark:text-gray-300" style="margin: 0 auto;" data-i18n="services.desc">{{ t.services.desc }}</p>
      </div>

      <div class="services-grid" id="servicesGrid">
        {% for svc in t.services.items %}
        <div class="service-card fade-in">
          <div class="service-card-image">
            <img src="{{ svc.image }}" alt="{{ svc.title }}" width="600" height="400" loading="lazy" decoding="async">
          </div>
          <div class="service-card-body">
            <h3>{{ svc.title }}</h3>
            <p>{{ svc.desc }}</p>
            <div class="service-card-footer">
              <span class="service-price">{{ svc.price }} <span>{{ svc.unit }}</span></span>
              <a href="/register" class="btn btn-outline btn-sm" data-i18n="services.request">{{ t.services.request }}</a>
            </div>
          </div>
        </div>
        {% endfor %}
      </div>


    </div>
  </section>

      {# ════════════ EXHIBITIONS ════════════ #}
      <section class="landing-view" id="exhibitions">
    <div class="container">
      <div class="text-center fade-in">
        <span class="section-label" data-i18n="exhibitions.label">{{ t.exhibitions.label }}</span>
        <h2 class="section-title"><span data-i18n="exhibitions.title_before">{{ t.exhibitions.title_before | safe }}</span> <span class="text-gradient" data-i18n="exhibitions.title_highlight">{{ t.exhibitions.title_highlight | safe }}</span></h2>
        <p class="section-desc text-gray-800 dark:text-gray-300" style="margin: 0 auto;" data-i18n="exhibitions.desc">{{ t.exhibitions.desc }}</p>
      </div>

      <div class="exhibitions-grid" id="exhibitionsGrid">
        <!-- Injected dynamically by landing.js -->
      </div>


    </div>
  </section>

      {# ════════════ JOBS ════════════ #}
      <section class="landing-view" id="jobs">
    <div class="container">
      <div class="text-center fade-in">
        <span class="section-label" data-i18n="jobs.label">{{ t.jobs.label }}</span>
        <h2 class="section-title"><span data-i18n="jobs.title_before">{{ t.jobs.title_before | safe }}</span> <span class="text-gradient" data-i18n="jobs.title_highlight">{{ t.jobs.title_highlight | safe }}</span></h2>
        <p class="section-desc text-gray-800 dark:text-gray-300" style="margin: 0 auto;" data-i18n="jobs.desc">{{ t.jobs.desc }}</p>
      </div>

      <div class="properties-grid" id="jobsGrid">
        <!-- Injected dynamically by landing.js -->
      </div>


    </div>
  </section>

      {# ════════════ PORTFOLIO ════════════ #}
      <section class="landing-view" id="portfolio">
    <div class="container">
      <div class="text-center fade-in">
        <span class="section-label" data-i18n="portfolio.label">{{ t.portfolio.label | default('Portfolio') }}</span>
        <h2 class="section-title">
          <span data-i18n="portfolio.title_before">{{ t.portfolio.title_before | default('Our') | safe }}</span>
          <span class="text-gradient" data-i18n="portfolio.title_highlight">{{ t.portfolio.title_highlight | default('Best Works') | safe }}</span>
        </h2>
        <p class="section-desc text-gray-800 dark:text-gray-300" style="margin: 0 auto;" data-i18n="portfolio.desc">
          {{ t.portfolio.desc | default('Explore our featured projects and creative work') }}
        </p>
      </div>

      <div class="portfolio-filters" id="portfolioFilters">
        <button class="filter-btn active" data-filter="all">{{ t.portfolio.allWorks | default('All Works') }}</button>
      </div>

      <div class="portfolio-grid" id="portfolioGrid">
        <!-- Loaded dynamically by landing.js -->
      </div>
    </div>
  </section>




      <section class="landing-view" id="contact">
    <div class="container">
      <div class="text-center fade-in">
        <span class="section-label" data-i18n="contact.label">{{ t.contact.label }}</span>
        <h2 class="section-title"><span data-i18n="contact.title_before">{{ t.contact.title_before | safe }}</span> <span class="text-gradient" data-i18n="contact.title_highlight">{{ t.contact.title_highlight | safe }}</span></h2>
        <p class="section-desc text-gray-800 dark:text-gray-300" style="margin: 0 auto;" data-i18n="contact.desc">{{ t.contact.desc }}</p>
      </div>

      <div class="contact-grid">
        <div class="contact-info fade-in-left">
          <div class="contact-info-item">
            <div class="icon"><i class="fas fa-envelope"></i></div>
            <div>
              <h3 data-i18n="contact.emailLabel" style="font-size:1.1rem;margin-bottom:4px">{{ t.contact.emailLabel }}</h3>
              <p>mohamedmahomoud809@gmail.com</p>
            </div>
          </div>
          <div class="contact-info-item">
            <div class="icon"><i class="fas fa-phone"></i></div>
            <div>
              <h3 data-i18n="contact.phoneLabel" style="font-size:1.1rem;margin-bottom:4px">{{ t.contact.phoneLabel }}</h3>
              <p><span dir="ltr" style="display: inline-block;">+20 1025474922</span></p>
            </div>
          </div>
          <div class="contact-info-item">
            <div class="icon"><i class="fab fa-whatsapp"></i></div>
            <div>
              <h3 data-i18n="contact.whatsappLabel" style="font-size:1.1rem;margin-bottom:4px">{{ t.contact.whatsappLabel }}</h3>
              <p><span dir="ltr" style="display: inline-block;">+966 548 171 795</span></p>
            </div>
          </div>
          <div class="contact-info-item">
            <div class="icon"><i class="fas fa-location-dot"></i></div>
            <div>
              <h3 data-i18n="contact.visitLabel" style="font-size:1.1rem;margin-bottom:4px">{{ t.contact.visitLabel }}</h3>
              <a href="https://maps.app.goo.gl/rVD1Xd9ezUy7snEY8" target="_blank" rel="noopener noreferrer" style="color:var(--text-muted);text-decoration:none;transition:color 0.25s ease;" onmouseover="this.style.color='var(--accent-primary)'" onmouseout="this.style.color='var(--text-muted)'" data-i18n="contact.address">{{ t.contact.address }}</a>
            </div>
          </div>
        </div>

        <form class="contact-form fade-in-right" id="contactForm">
          <div class="form-row">
            <div class="form-group">
              <label class="form-label" for="contactName" data-i18n="contact.form_name">{{ t.contact.form_name }}</label>
              <input class="form-input" type="text" id="contactName" placeholder="{{ t.contact.form_name_placeholder }}" data-i18n="contact.form_name_placeholder" required>
            </div>
            <div class="form-group">
              <label class="form-label" for="contactEmail" data-i18n="contact.form_email">{{ t.contact.form_email }}</label>
              <input class="form-input" type="email" id="contactEmail" placeholder="{{ t.contact.form_email_placeholder }}" data-i18n="contact.form_email_placeholder" required>
            </div>
          </div>
          <div class="form-group">
            <label class="form-label" for="contactSubject" data-i18n="contact.form_subject">{{ t.contact.form_subject }}</label>
            <input class="form-input" type="text" id="contactSubject" placeholder="{{ t.contact.form_subject_placeholder }}" data-i18n="contact.form_subject_placeholder">
          </div>
          <div class="form-group">
            <label class="form-label" for="contactMessage" data-i18n="contact.form_message">{{ t.contact.form_message }}</label>
            <textarea class="form-textarea" id="contactMessage" placeholder="{{ t.contact.form_message_placeholder }}" data-i18n="contact.form_message_placeholder" required></textarea>
          </div>
          <button type="submit" class="btn btn-primary btn-lg w-full">
            <i class="fas fa-paper-plane"></i> <span data-i18n="contact.form_submit">{{ t.contact.form_submit }}</span>
          </button>
        </form>
      </div>
    </div>
      </section>

      {# ════════════ COMPANY LOCATION ════════════ #}
      <section class="landing-view" id="location">
    <div class="container">
      <div class="text-center fade-in">
        <span class="section-label" data-i18n="location.label">{{ t.location.label | default('Our Location') }}</span>
        <h2 class="section-title">
          <span data-i18n="location.title_before">{{ t.location.title_before | default('Company') | safe }}</span>
          <span class="text-gradient" data-i18n="location.title_highlight">{{ t.location.title_highlight | default('Headquarters') | safe }}</span>
        </h2>
        <p class="section-desc" style="margin: 0 auto;" data-i18n="location.desc">
          {{ t.location.desc | default('Visit us at our office or find us on the map') }}
        </p>
      </div>

      <div class="location-map-wrapper fade-in">
        <div class="location-map-frame">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m17!1m12!1m3!1d3450.0719572817206!2d31.710670475557748!3d30.149358674870918!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m2!1m1!2zMzDCsDA4JzU3LjciTiAzMcKwNDInNDcuNyJF!5e0!3m2!1sen!2seg!4v1774907390244!5m2!1sen!2seg"
            width="100%"
            height="100%"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Nabda Company Location">
          </iframe>
        </div>
        <div class="location-cta">
          <a href="https://maps.app.goo.gl/rVD1Xd9ezUy7snEY8"
             target="_blank"
             rel="noopener noreferrer"
             class="btn btn-primary btn-lg location-btn"
             data-i18n="location.openInMaps">
            <i class="fas fa-map-marker-alt"></i>
            {{ t.location.openInMaps | default('📍 افتح الموقع في خرائط جوجل') }}
          </a>
        </div>
      </div>
    </div>
  </section>
    </div>
{% endblock %}

{% block pageScripts %}
  <script src="/js/landing.js?v=5" defer></script>
{% endblock %}
